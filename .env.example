# ─────────────────────────────────────────────────────────────
#  EduWeb Planner — Variables d'environnement (modèle)
#  Copier ce fichier en `.env` puis renseigner les valeurs réelles.
#  ⚠️ Ne JAMAIS committer le fichier `.env` (clés secrètes).
# ─────────────────────────────────────────────────────────────

# Base de données PostgreSQL (Neon).
# Format : postgresql://user:password@host/db?sslmode=require
# Neon fournit deux URL : une "pooled" (runtime) et une "direct" (migrations).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# URL directe (sans pooler) pour `prisma migrate`. Optionnelle si DATABASE_URL est directe.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js (NextAuth v5). Générer un secret : `npx auth secret` ou `openssl rand -base64 32`.
AUTH_SECRET="remplacer-par-un-secret-aleatoire-long"
# URL publique de l'application (utilisée dans les liens e-mail).
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend — e-mails transactionnels (confirmation, réinitialisation, notifications).
RESEND_API_KEY=""
# Adresse expéditrice vérifiée dans Resend.
EMAIL_FROM="EduWeb Planner <no-reply@exemple.ci>"

# Stripe — facturation des établissements (Phase 7). Secrets côté serveur uniquement.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─────────────────────────────────────────────────────────────
#  IA — Anthropic (Claude) : appréciations détaillées des copies, note suggérée,
#  suggestions du registre d'appel, génération de cours et chatbot d'assistance.
#  Sans clé, ces fonctions basculent sur un repli local (aucune IA). Secret serveur.
ANTHROPIC_API_KEY=""
# Modèle Claude (optionnel). Défaut : claude-opus-4-8.
ANTHROPIC_MODEL="claude-opus-4-8"

# Voix OpenAI (une seule clé pour la SYNTHÈSE VOCALE et la DICTÉE/TRANSCRIPTION).
# ⚠️ Claude ne fait PAS de voix : fournisseur compatible OpenAI (audio/speech + audio/transcriptions).
# Sans TTS_API_KEY : lecture audio → voix du navigateur (gratuite) ; dictée → bouton masqué.
TTS_API_KEY=""
TTS_BASE_URL="https://api.openai.com/v1"
# Synthèse vocale (lecture des narratifs).
TTS_MODEL="gpt-4o-mini-tts"
TTS_VOICE="alloy"
# Transcription (dictée vocale : audio → texte).
TRANSCRIPTION_MODEL="gpt-4o-mini-transcribe"

# ─────────────────────────────────────────────────────────────
#  Tâches planifiées (Vercel Cron) — secret de protection des routes /api/cron/*.
#  Définir la MÊME valeur dans les variables d'environnement Vercel : Vercel envoie alors
#  automatiquement l'en-tête « Authorization: Bearer <CRON_SECRET> » aux tâches planifiées.
#  Utilisé par /api/cron/fin-essai (e-mail automatique de fin de période d'essai).
CRON_SECRET=""
