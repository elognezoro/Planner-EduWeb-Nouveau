// EduWeb Planner — Schéma Prisma de référence
// Phase 0/1 : RBAC à périmètre + authentification.
// Les entités de périmètre (Region, Etablissement, Cafop, Apfc) sont posées ici
// en version minimale ; elles seront étoffées en Phase 2 (cf. cahier des charges §3.1).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 7 : l'URL n'est plus déclarée ici.
  // - Au runtime, elle est fournie via le driver adapter (@prisma/adapter-pg) — voir src/lib/prisma.ts.
  // - Pour les migrations, elle est lue depuis prisma.config.ts (env DIRECT_URL).
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
//  Énumérations
// ─────────────────────────────────────────────────────────────

/// Statut du COMPTE — découplé du statut de la demande de rôle (cahier §6.1).
enum StatutCompte {
  en_attente_verification // inscrit, e-mail pas encore confirmé
  actif // e-mail confirmé : peut se connecter
  suspendu
}

/// Statut d'une demande de rôle (cahier §6.6).
enum StatutDemandeRole {
  en_attente
  approuvee
  refusee
}

/// Type de jeton à usage unique (vérification e-mail / réinitialisation mot de passe).
enum TypeJeton {
  verification_email
  reinitialisation_mot_de_passe
}

// ── Phase 2 : structure & établissements ──

enum TypeEtablissement {
  prescolaire
  primaire
  college
  lycee
  groupe_scolaire
  autre
}

enum StatutEtablissement {
  public
  prive
  confessionnel
  autre
}

enum TypeSalle {
  ordinaire
  laboratoire
  salle_informatique
  atelier
  salle_eps
  autre
}

/// Cycle d'un niveau scolaire.
enum CycleNiveau {
  prescolaire
  primaire
  college
  lycee
}

/// Régime de vacation (cahier §5.3.0-e) : simple ou double vacation.
enum RegimeVacation {
  simple
  double
}

/// Régime de notation par défaut (cahier §5.2.17).
enum RegimeNotation {
  trimestre
  semestre
}

/// Statut de présence d'un élève sur une séance (cahier §5.3.1).
enum StatutPresence {
  present
  absent
  retard
  excuse
}

/// Nature d'une notification in-app (pilote l'icône et la couleur d'affichage).
enum TypeNotification {
  info
  succes
  alerte
  role
}

/// Type de visite d'inspection (cahier §5 — inspection & supervision).
enum TypeVisite {
  classe
  etablissement
  suivi
}

/// Statut d'une visite d'inspection.
enum StatutVisite {
  planifiee
  realisee
  annulee
}

/// Priorité d'une recommandation d'inspection.
enum PrioriteRecommandation {
  basse
  moyenne
  haute
}

/// Statut de traitement d'une recommandation.
enum StatutRecommandation {
  ouverte
  en_cours
  traitee
}

/// Nature d'une cohorte de formation (cahier partie 5 — CAFOP & APFC).
enum TypeCohorte {
  cafop_promotion // promotion d'élèves-maîtres (CAFOP)
  apfc_session // session de formation continue (APFC)
}

/// Statut d'une cohorte de formation.
enum StatutCohorte {
  active
  cloturee
}

/// Formule d'abonnement Académie Premium (tarif selon l'effectif de l'établissement).
enum FormulePremium {
  petit // < 800 élèves
  grand // ≥ 800 élèves
}

/// Moyen de paiement (carte bancaire + Mobile Money ivoiriens).
enum ModePaiement {
  carte
  wave
  orange
  mtn
  moov
}

/// Statut d'un abonnement Premium.
enum StatutAbonnement {
  en_attente
  actif
  expire
}

/// Statut d'une demande de code promo (instruite par l'admin).
enum StatutDemandePromo {
  en_attente
  approuvee
  refusee
}

/// Nature d'une alerte SMS envoyée aux parents.
enum TypeAlerteSMS {
  absence
  note
  convocation
  info
}

/// Statut d'envoi d'un SMS (simulé tant qu'aucun fournisseur n'est branché).
enum StatutSMS {
  simule
  envoye
  echec
}

/// Statut d'un rendez-vous (parent ↔ personnel).
enum StatutRendezVous {
  demande
  confirme
  refuse
  annule
}

// ─────────────────────────────────────────────────────────────
//  RBAC : Rôle, Utilisateur, Demande de rôle
// ─────────────────────────────────────────────────────────────

/// Définition statique d'un profil d'accès (les 13 rôles, cahier §4.1).
model Role {
  id           String  @id @default(cuid())
  nomTechnique String  @unique // ex : "admin", "enseignant" (snake_case, cf. CLAUDE.md §8)
  libelle      String // ex : "Administrateur Système"
  description  String?
  rang         Int     @default(0) // ordre d'affichage / niveau de privilège indicatif

  utilisateurs Utilisateur[] @relation("RoleActif")
  demandes     DemandeRole[] @relation("RoleDemande")

  @@map("roles")
}

/// Compte d'un acteur de la plateforme (cahier §3.1, §4.2).
model Utilisateur {
  id             String       @id @default(cuid())
  email          String       @unique
  motDePasseHash String
  nom            String?
  prenoms        String?
  telephone      String?
  sexe           String? // « F » / « M » — affiché notamment au registre d'appel
  matricule      String? // matricule élève (registre, bulletins)
  photoUrl       String?
  statutCompte   StatutCompte @default(en_attente_verification)
  emailVerifieLe DateTime?
  langue         String       @default("fr")

  // Rôle actif (technique). À l'inscription = "eleve" par défaut (cahier §6.2).
  roleActifId String
  roleActif   Role   @relation("RoleActif", fields: [roleActifId], references: [id])

  // Périmètre — nullable selon le rôle (cahier §3.2, §4.2).
  etablissementId String?
  etablissement   Etablissement? @relation(fields: [etablissementId], references: [id])
  cafopId         String?
  cafop           Cafop?         @relation(fields: [cafopId], references: [id])
  apfcId          String?
  apfc            Apfc?          @relation(fields: [apfcId], references: [id])
  regionId        String?
  region          Region?        @relation(fields: [regionId], references: [id])

  // Relations
  demandes         DemandeRole[]     @relation("DemandeUtilisateur")
  demandesTraitees DemandeRole[]     @relation("DemandeTraitePar")
  liensCommeParent LienParentEleve[] @relation("Parent")
  liensCommeEleve  LienParentEleve[] @relation("Eleve")
  jetons           Jeton[]
  // Vie scolaire (Phase 3)
  affectations     AffectationEnseignant[] @relation("AffectationsEnseignant")
  inscriptions     Inscription[]           @relation("InscriptionsEleve")
  appelsSaisis     Appel[]                 @relation("AppelsSaisis")
  presences        Presence[]              @relation("Presences")
  notesEleve         Note[]                  @relation("NotesEleve")
  notesSaisies       Note[]                  @relation("NotesSaisies")
  cahiersSaisis      CahierTexte[]           @relation("CahiersSaisis")
  notifications      Notification[]          @relation("NotificationsRecues")
  messagesEnvoyes    Message[]               @relation("MessagesEnvoyes")
  messagesRecus      Message[]               @relation("MessagesRecus")
  demandesPromo      DemandeCodePromo[]      @relation("DemandesPromo")
  abonnementsSouscrits AbonnementPremium[]   @relation("AbonnementsSouscrits")
  rdvDemandes        RendezVous[]            @relation("RdvDemandes")
  rdvRecus           RendezVous[]            @relation("RdvRecus")
  visitesInspecteur  Visite[]                @relation("VisitesInspecteur")
  visitesEnseignant  Visite[]                @relation("VisitesEnseignant")
  competences        CompetenceEnseignant[]  @relation("CompetencesEnseignant")
  niveauxIntervention NiveauEnseignant[]     @relation("NiveauxEnseignant")

  creeLe     DateTime @default(now())
  misAJourLe DateTime @updatedAt

  @@index([roleActifId])
  @@index([etablissementId])
  @@index([cafopId])
  @@index([apfcId])
  @@index([regionId])
  @@map("utilisateurs")
}

/// Demande d'attribution / changement de rôle (couvre l'inscription initiale, cahier §6).
model DemandeRole {
  id            String      @id @default(cuid())
  utilisateurId String
  utilisateur   Utilisateur @relation("DemandeUtilisateur", fields: [utilisateurId], references: [id], onDelete: Cascade)

  roleDemandeId String
  roleDemande   Role   @relation("RoleDemande", fields: [roleDemandeId], references: [id])

  statut StatutDemandeRole @default(en_attente)

  // Périmètre DÉCLARÉ par le demandeur (texte libre + identifiants si connus).
  structureDeclaree      String? // ex : nom de l'établissement saisi à l'inscription
  etablissementDeclareId String?
  cafopDeclareId         String?
  apfcDeclareId          String?
  regionDeclareeId       String?

  motif      String? // message du demandeur et/ou commentaire de l'administrateur
  creeLe     DateTime  @default(now())
  traiteLe   DateTime?
  // Anticipe la délégation future par périmètre (cahier §6.4) — aucune migration requise plus tard.
  traiteParId String?
  traitePar   Utilisateur? @relation("DemandeTraitePar", fields: [traiteParId], references: [id])

  @@index([statut])
  @@index([utilisateurId])
  @@map("demandes_role")
}

/// Relation N↔N entre un compte parent et un ou plusieurs comptes élèves (cahier §3.3).
model LienParentEleve {
  id       String      @id @default(cuid())
  parentId String
  parent   Utilisateur @relation("Parent", fields: [parentId], references: [id], onDelete: Cascade)
  eleveId  String
  eleve    Utilisateur @relation("Eleve", fields: [eleveId], references: [id], onDelete: Cascade)
  lien     String? // "père", "mère", "tuteur légal"…
  creeLe   DateTime    @default(now())

  @@unique([parentId, eleveId])
  @@index([parentId])
  @@index([eleveId])
  @@map("liens_parent_eleve")
}

/// Jeton à usage unique pour la confirmation d'e-mail et la réinitialisation de mot de passe (cahier §6.2, §6.5).
model Jeton {
  id            String      @id @default(cuid())
  token         String      @unique
  type          TypeJeton
  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  expireLe      DateTime
  utiliseLe     DateTime?
  creeLe        DateTime    @default(now())

  @@index([utilisateurId])
  @@map("jetons")
}

// ─────────────────────────────────────────────────────────────
//  Entités de périmètre (minimales en Phase 1, étoffées en Phase 2)
// ─────────────────────────────────────────────────────────────

/// Découpage administratif régional (rattachement DRENA/DRENAET, cahier §3.1).
/// Surcharge d'une permission de module pour un rôle (matrice des droits éditable).
/// Une ligne absente = valeur par défaut de la carte de navigation (item.roles).
/// `itemId` = identifiant d'ItemNav (ex : "registre-appel") ; `role` = nomTechnique du rôle.
model PermissionRole {
  id         String   @id @default(cuid())
  itemId     String
  role       String
  accorde    Boolean
  misAJourLe DateTime @updatedAt

  @@unique([itemId, role])
  @@map("permissions_role")
}

model Region {
  id   String  @id @default(cuid())
  nom  String
  code String? @unique
  /// Pays de rattachement — permet des répertoires régionaux multi-pays (déploiement sous-régional).
  pays String  @default("Côte d'Ivoire")

  etablissements Etablissement[]
  cafops         Cafop[]
  apfcs          Apfc[]
  utilisateurs   Utilisateur[]

  creeLe DateTime @default(now())

  @@unique([pays, nom])
  @@map("regions")
}

/// Établissement scolaire (cahier §3.1). Étendu en Phase 2bis avec la configuration
/// complète servant d'intrant au module Emplois du temps (cf. console de configuration).
model Etablissement {
  id        String              @id @default(cuid())
  nom       String
  code      String?             @unique
  type      TypeEtablissement   @default(college)
  statut    StatutEtablissement @default(public)
  ville     String?
  adresse   String?
  email     String?
  telephone String?
  /// Régime de vacation par défaut de l'établissement (surchargé par niveau si besoin).
  regimeVacation RegimeVacation @default(simple)

  // ── Étape 1 : paramétrage institutionnel & en-tête de bulletin ──
  pays          String? @default("Côte d'Ivoire")
  sloganBulletin String? @default("Union – Discipline – Travail")
  ministere     String?
  anneeScolaire String? // ex : « 2025-2026 »
  fonctionChef  String? // ex : « Proviseur »
  nomChef       String? // nom et prénoms du chef d'établissement
  // Documents officiels (URLs Vercel Blob)
  emblemeUrl   String?
  logoUrl      String?
  cachetUrl    String?
  signatureUrl String?
  // Rapport d'établissement
  planRapport         String?
  presentationRapport String? @default("Accordéon")

  // ── Étape 2 : dimensionnement & horaires ──
  effectifSouhaiteParClasse Int @default(40)
  nbSallesDisponibles       Int @default(0)
  creneauxParJour           Int @default(8)
  // Horaires journaliers (format « HH:MM »)
  horaireDebutMatin       String? @default("07:30")
  horairePauseMatinDebut  String? @default("09:45")
  horairePauseMatinFin    String? @default("10:05")
  horairePauseMidiDebut   String? @default("12:00")
  horaireRepriseApresMidi String? @default("15:00")
  horaireFinJournee       String? @default("18:00")

  regionId String?
  region   Region? @relation(fields: [regionId], references: [id])

  utilisateurs   Utilisateur[]
  classes        Classe[]
  salles         Salle[]
  grilles        GrilleHoraire[]
  niveauxConfig  NiveauEtablissement[]
  champsEnseignant ChampEnseignant[]
  competences    CompetenceEnseignant[]
  niveauxEnseignant NiveauEnseignant[]
  effectifsEnseignant EffectifEnseignant[]
  creneaux       Creneau[]
  visites        Visite[]
  abonnementsPremium AbonnementPremium[]

  creeLe     DateTime @default(now())
  misAJourLe DateTime @updatedAt

  @@index([regionId])
  @@map("etablissements")
}

/// Configuration d'un niveau pour un établissement : effectif total, vacation, classes calculées.
model NiveauEtablissement {
  id              String         @id @default(cuid())
  etablissementId String
  etablissement   Etablissement  @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  niveauId        String
  niveau          Niveau         @relation(fields: [niveauId], references: [id], onDelete: Cascade)
  effectif        Int            @default(0)
  vacation        RegimeVacation @default(simple)
  nbClasses       Int            @default(0)

  @@unique([etablissementId, niveauId])
  @@index([etablissementId])
  @@map("niveaux_etablissement")
}

/// Champ personnalisé requis pour l'enregistrement des enseignants d'un établissement.
model ChampEnseignant {
  id              String        @id @default(cuid())
  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  etiquette       String
  type            String        @default("text") // text | date | number | select
  placeholder     String?
  requis          Boolean       @default(false)
  ordre           Int           @default(0)

  @@index([etablissementId])
  @@map("champs_enseignant")
}

/// Compétence d'un enseignant : discipline qu'il est habilité à enseigner (intrant du solveur).
model CompetenceEnseignant {
  id              String        @id @default(cuid())
  enseignantId    String
  enseignant      Utilisateur   @relation("CompetencesEnseignant", fields: [enseignantId], references: [id], onDelete: Cascade)
  disciplineId    String
  discipline      Discipline    @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)

  @@unique([enseignantId, disciplineId])
  @@index([etablissementId])
  @@map("competences_enseignant")
}

/// Niveau auquel un enseignant intervient (intrant de l'affectation automatique).
model NiveauEnseignant {
  id              String        @id @default(cuid())
  enseignantId    String
  enseignant      Utilisateur   @relation("NiveauxEnseignant", fields: [enseignantId], references: [id], onDelete: Cascade)
  niveauId        String
  niveau          Niveau        @relation(fields: [niveauId], references: [id], onDelete: Cascade)
  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)

  @@unique([enseignantId, niveauId])
  @@index([etablissementId])
  @@map("niveaux_enseignant")
}

/// Effectif d'enseignants déclaré par cycle et discipline (intrant du solveur, approche par compteurs).
model EffectifEnseignant {
  id              String        @id @default(cuid())
  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  disciplineId    String
  discipline      Discipline    @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  cycle           CycleNiveau
  nombre          Int           @default(0)

  @@unique([etablissementId, disciplineId, cycle])
  @@index([etablissementId])
  @@map("effectifs_enseignant")
}

/// Niveau scolaire national (ex : 6ème, Seconde C) — cahier §3.1.
model Niveau {
  id    String      @id @default(cuid())
  nom   String      @unique
  code  String?     @unique
  ordre Int         @default(0)
  cycle CycleNiveau @default(college)

  classes       Classe[]
  grilles       GrilleHoraire[]
  niveauxConfig NiveauEtablissement[]
  enseignants   NiveauEnseignant[]

  @@map("niveaux")
}

/// Discipline / matière enseignée — cahier §3.1.
model Discipline {
  id      String  @id @default(cuid())
  nom     String  @unique
  code    String? @unique
  couleur String? // code couleur pour l'affichage des emplois du temps

  grilles      GrilleHoraire[]
  affectations AffectationEnseignant[]
  appels       Appel[]
  notes        Note[]
  cahiers      CahierTexte[]
  competences  CompetenceEnseignant[]
  effectifsEnseignant EffectifEnseignant[]

  @@map("disciplines")
}

/// Classe pédagogique au sein d'un établissement (ex : 6ème A) — cahier §3.1.
model Classe {
  id       String @id @default(cuid())
  nom      String
  effectif Int    @default(0)

  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  niveauId        String
  niveau          Niveau        @relation(fields: [niveauId], references: [id])

  anneeScolaireId String?
  anneeScolaire   AnneeScolaire? @relation(fields: [anneeScolaireId], references: [id])

  regimeVacation RegimeVacation @default(simple)

  affectations AffectationEnseignant[]
  inscriptions Inscription[]
  appels       Appel[]
  notes        Note[]
  cahiers      CahierTexte[]

  creeLe     DateTime @default(now())
  misAJourLe DateTime @updatedAt

  @@index([etablissementId])
  @@index([niveauId])
  @@map("classes")
}

/// Salle physique d'un établissement (capacité + type) — cahier §3.1, §5.3.0-e.
model Salle {
  id        String    @id @default(cuid())
  nom       String
  capacite  Int       @default(0)
  type      TypeSalle @default(ordinaire)

  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)

  creeLe DateTime @default(now())

  @@index([etablissementId])
  @@map("salles")
}

/// Année scolaire (ex : « 2025-2026 ») — base des inscriptions (cahier §5.2.17).
model AnneeScolaire {
  id      String    @id @default(cuid())
  libelle String    @unique
  debut   DateTime?
  fin     DateTime?
  active  Boolean   @default(false)

  classes      Classe[]
  inscriptions Inscription[]

  @@map("annees_scolaires")
}

/// Grille horaire : volume hebdomadaire par niveau et discipline (cahier §5.3.0-e).
/// `etablissementId` null = modèle national par défaut ; non-null = surcharge établissement.
model GrilleHoraire {
  id          String @id @default(cuid())
  niveauId    String
  niveau      Niveau @relation(fields: [niveauId], references: [id], onDelete: Cascade)
  disciplineId String
  discipline  Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)

  etablissementId String?
  etablissement   Etablissement? @relation(fields: [etablissementId], references: [id], onDelete: Cascade)

  heuresHebdo    Float @default(0) // volume horaire hebdomadaire (heures), dérivé des séances
  nbSeances      Int?  // nombre de séances hebdomadaires
  coefficient    Float @default(1)
  seancesMinutes Int[] @default([]) // durées (min) de chaque séance hebdomadaire — ex : [60,60,60,60]

  @@unique([niveauId, disciplineId, etablissementId])
  @@index([niveauId])
  @@index([etablissementId])
  @@map("grilles_horaires")
}

/// Configuration globale de la plateforme (singleton) — cahier §5.2.17.
model Configuration {
  id                   String         @id @default("global")
  anneeScolaireCourante String?
  regimeNotation       RegimeNotation @default(trimestre)
  misAJourLe           DateTime       @updatedAt

  @@map("configuration")
}

/// Centre d'Animation et de Formation Pédagogique (cahier §3.1).
model Cafop {
  id       String  @id @default(cuid())
  nom      String
  regionId String?
  region   Region? @relation(fields: [regionId], references: [id])

  utilisateurs Utilisateur[]
  cohortes     Cohorte[]

  creeLe DateTime @default(now())

  @@index([regionId])
  @@map("cafops")
}

/// Antenne Pédagogique de Formation Continue (cahier §3.1).
model Apfc {
  id       String  @id @default(cuid())
  nom      String
  regionId String?
  region   Region? @relation(fields: [regionId], references: [id])

  utilisateurs Utilisateur[]
  cohortes     Cohorte[]

  creeLe DateTime @default(now())

  @@index([regionId])
  @@map("apfc")
}

/// Cohorte de formation : promotion d'élèves-maîtres (CAFOP) ou session de formation
/// continue (APFC). Rattachée à l'une des deux structures selon `type` (cahier partie 5).
model Cohorte {
  id        String        @id @default(cuid())
  type      TypeCohorte
  cafopId   String?
  cafop     Cafop?        @relation(fields: [cafopId], references: [id], onDelete: Cascade)
  apfcId    String?
  apfc      Apfc?         @relation(fields: [apfcId], references: [id], onDelete: Cascade)
  libelle   String
  anneeDebut Int?
  anneeFin   Int?
  dateDebut  DateTime?
  dateFin    DateTime?
  lieu       String?
  statut    StatutCohorte @default(active)

  apprenants Apprenant[]

  creeLe DateTime @default(now())

  @@index([cafopId])
  @@index([apfcId])
  @@map("cohortes")
}

/// Apprenant d'une cohorte (élève-maître ou participant à une formation continue).
/// Simple enregistrement de liste (pas un compte Utilisateur) — alimenté par import CSV Moodle.
model Apprenant {
  id                   String   @id @default(cuid())
  cohorteId            String
  cohorte              Cohorte  @relation(fields: [cohorteId], references: [id], onDelete: Cascade)
  matricule            String?
  nom                  String
  prenoms              String?
  email                String?
  etablissementOrigine String?
  creeLe               DateTime @default(now())

  @@index([cohorteId])
  @@map("apprenants")
}

// ─────────────────────────────────────────────────────────────
//  Vie scolaire — Phase 3
// ─────────────────────────────────────────────────────────────

/// Affectation d'un enseignant à une classe pour une discipline (cahier §3.1, §8.5).
model AffectationEnseignant {
  id           String      @id @default(cuid())
  enseignantId String
  enseignant   Utilisateur @relation("AffectationsEnseignant", fields: [enseignantId], references: [id], onDelete: Cascade)
  classeId     String
  classe       Classe      @relation(fields: [classeId], references: [id], onDelete: Cascade)
  disciplineId String
  discipline   Discipline  @relation(fields: [disciplineId], references: [id])

  creeLe DateTime @default(now())

  @@unique([enseignantId, classeId, disciplineId])
  @@index([classeId])
  @@index([enseignantId])
  @@map("affectations_enseignant")
}

/// Inscription d'un élève à une classe pour une année scolaire (cahier §3.1, §8.5).
model Inscription {
  id      String      @id @default(cuid())
  eleveId String
  eleve   Utilisateur @relation("InscriptionsEleve", fields: [eleveId], references: [id], onDelete: Cascade)
  classeId String
  classe   Classe     @relation(fields: [classeId], references: [id], onDelete: Cascade)

  anneeScolaireId String?
  anneeScolaire   AnneeScolaire? @relation(fields: [anneeScolaireId], references: [id])

  creeLe DateTime @default(now())

  @@unique([eleveId, anneeScolaireId])
  @@index([classeId])
  @@index([eleveId])
  @@map("inscriptions")
}

/// Séance d'appel pour une classe à une date donnée (cahier §5.3.1).
model Appel {
  id           String      @id @default(cuid())
  classeId     String
  classe       Classe      @relation(fields: [classeId], references: [id], onDelete: Cascade)
  disciplineId String?
  discipline   Discipline? @relation(fields: [disciplineId], references: [id])
  date         DateTime // jour de la séance (normalisé à minuit UTC)
  heureSeance  String? // créneau de la séance, ex : « 07h30 - 08h30 » (filtre + heatmap)
  saisiParId   String
  saisiPar     Utilisateur @relation("AppelsSaisis", fields: [saisiParId], references: [id])

  presences Presence[]

  creeLe DateTime @default(now())

  @@index([classeId])
  @@index([date])
  @@map("appels")
}

/// Présence d'un élève sur une séance d'appel (cahier §5.3.1).
model Presence {
  id          String         @id @default(cuid())
  appelId     String
  appel       Appel          @relation(fields: [appelId], references: [id], onDelete: Cascade)
  eleveId     String
  eleve       Utilisateur    @relation("Presences", fields: [eleveId], references: [id], onDelete: Cascade)
  statut      StatutPresence @default(present)
  commentaire String?
  motif       String? // motif d'absence / de retard (colonne MOTIF du registre)
  justifie    Boolean        @default(false) // absence/retard justifié auprès de l'établissement

  @@unique([appelId, eleveId])
  @@index([eleveId])
  @@map("presences")
}

/// Créneau d'emploi du temps généré (cahier §5.3.0). Noms dénormalisés pour un affichage direct.
model Creneau {
  id              String        @id @default(cuid())
  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  classeId        String
  classeNom       String
  disciplineId    String
  disciplineNom   String
  enseignantId    String
  enseignantNom   String
  salleNom        String
  jour            Int // 0 = lundi … 5 = samedi
  periode         Int // index de période dans la journée
  duree           Int @default(1) // nombre de périodes
  anneeScolaireId String?
  creeLe          DateTime @default(now())

  @@index([etablissementId])
  @@index([classeId])
  @@map("creneaux")
}

/// Note d'évaluation d'un élève dans une discipline, pour une période (cahier §5.3.4).
model Note {
  id           String      @id @default(cuid())
  eleveId      String
  eleve        Utilisateur @relation("NotesEleve", fields: [eleveId], references: [id], onDelete: Cascade)
  classeId     String
  classe       Classe      @relation(fields: [classeId], references: [id], onDelete: Cascade)
  disciplineId String
  discipline   Discipline  @relation(fields: [disciplineId], references: [id])

  libelle    String // ex : « Devoir 1 », « Composition »
  valeur     Float
  sur        Float  @default(20)
  periode    Int    @default(1) // 1..3 (trimestre) ou 1..2 (semestre)
  saisiParId String
  saisiPar   Utilisateur @relation("NotesSaisies", fields: [saisiParId], references: [id])

  creeLe DateTime @default(now())

  @@index([classeId])
  @@index([eleveId])
  @@index([disciplineId])
  @@map("notes")
}

/// Entrée du cahier de texte : contenu d'une séance et travail à faire, consigné par
/// l'enseignant pour une classe/discipline à une date donnée (cahier §5.3.2).
model CahierTexte {
  id           String      @id @default(cuid())
  classeId     String
  classe       Classe      @relation(fields: [classeId], references: [id], onDelete: Cascade)
  disciplineId String
  discipline   Discipline  @relation(fields: [disciplineId], references: [id])
  date         DateTime // jour de la séance (normalisé à minuit UTC)

  contenu       String // contenu de la séance / leçon traitée
  travailAFaire String? // devoirs / travail à faire à la maison

  saisiParId String
  saisiPar   Utilisateur @relation("CahiersSaisis", fields: [saisiParId], references: [id])

  creeLe     DateTime @default(now())
  misAJourLe DateTime @updatedAt

  @@index([classeId])
  @@index([disciplineId])
  @@index([date])
  @@map("cahier_texte")
}

/// Notification in-app destinée à un utilisateur (socle commun, cahier §5.3.x).
/// Tout module crée une notification via `creerNotification` (src/lib/notifications).
model Notification {
  id             String           @id @default(cuid())
  destinataireId String
  destinataire   Utilisateur      @relation("NotificationsRecues", fields: [destinataireId], references: [id], onDelete: Cascade)
  type           TypeNotification @default(info)
  titre          String
  message        String
  lien           String? // route interne optionnelle (ex : « /app/mon-identification »)
  lu             Boolean          @default(false)
  luLe           DateTime?
  creeLe         DateTime         @default(now())

  @@index([destinataireId, lu])
  @@index([creeLe])
  @@map("notifications")
}

/// Message in-app entre deux utilisateurs (communication interne, cahier partie 5/7).
model Message {
  id             String      @id @default(cuid())
  expediteurId   String
  expediteur     Utilisateur @relation("MessagesEnvoyes", fields: [expediteurId], references: [id], onDelete: Cascade)
  destinataireId String
  destinataire   Utilisateur @relation("MessagesRecus", fields: [destinataireId], references: [id], onDelete: Cascade)
  contenu        String
  lu             Boolean     @default(false)
  creeLe         DateTime    @default(now())

  @@index([expediteurId])
  @@index([destinataireId, lu])
  @@map("messages")
}

/// Code promotionnel applicable à un abonnement Premium (cahier partie 7 — Académie Premium).
model CodePromo {
  id          String   @id @default(cuid())
  code        String   @unique
  libelle     String
  pourcentage Int // remise en %
  partenaire  Boolean  @default(false) // taux préférentiel partenaire (IZEN, E-School…)
  actif       Boolean  @default(true)
  creeLe      DateTime @default(now())

  abonnements AbonnementPremium[]

  @@map("codes_promo")
}

/// Demande d'un code promo, instruite par l'administrateur (« Approbations de codes promos »).
model DemandeCodePromo {
  id               String             @id @default(cuid())
  demandeurId      String
  demandeur        Utilisateur        @relation("DemandesPromo", fields: [demandeurId], references: [id], onDelete: Cascade)
  etablissementNom String?
  motif            String
  statut           StatutDemandePromo @default(en_attente)
  codeAttribue     String?
  traiteLe         DateTime?
  creeLe           DateTime           @default(now())

  @@index([statut])
  @@map("demandes_code_promo")
}

/// Abonnement à l'Académie Premium pour un établissement (mode démo : paiement simulé).
model AbonnementPremium {
  id                   String           @id @default(cuid())
  etablissementId      String?
  etablissement        Etablissement?   @relation(fields: [etablissementId], references: [id], onDelete: SetNull)
  souscritParId        String
  souscritPar          Utilisateur      @relation("AbonnementsSouscrits", fields: [souscritParId], references: [id], onDelete: Cascade)
  formule              FormulePremium
  montantBase          Int // FCFA
  codePromoId          String?
  codePromo            CodePromo?       @relation(fields: [codePromoId], references: [id])
  pourcentageReduction Int              @default(0)
  montantFinal         Int // FCFA après remise
  modePaiement         ModePaiement
  statut               StatutAbonnement @default(en_attente)
  dateDebut            DateTime         @default(now())
  dateFin              DateTime
  creeLe               DateTime         @default(now())

  @@index([etablissementId])
  @@map("abonnements_premium")
}

/// Alerte SMS envoyée à un parent (un enregistrement par destinataire).
/// Champs dénormalisés : l'historique survit à la suppression des entités liées.
model AlerteSMS {
  id               String        @id @default(cuid())
  etablissementNom String?
  telephone        String
  contenu          String
  type             TypeAlerteSMS @default(info)
  statut           StatutSMS     @default(simule)
  envoyeParEmail   String?
  creeLe           DateTime      @default(now())

  @@index([creeLe])
  @@map("alertes_sms")
}

/// Rendez-vous entre un demandeur (parent/personnel) et un destinataire (personnel).
model RendezVous {
  id             String           @id @default(cuid())
  demandeurId    String
  demandeur      Utilisateur      @relation("RdvDemandes", fields: [demandeurId], references: [id], onDelete: Cascade)
  destinataireId String
  destinataire   Utilisateur      @relation("RdvRecus", fields: [destinataireId], references: [id], onDelete: Cascade)
  date           DateTime
  motif          String
  statut         StatutRendezVous @default(demande)
  creeLe         DateTime         @default(now())

  @@index([demandeurId])
  @@index([destinataireId])
  @@map("rendez_vous")
}

/// Visite d'inspection d'un établissement (et éventuellement d'un enseignant) — cahier partie 6.
model Visite {
  id              String        @id @default(cuid())
  inspecteurId    String
  inspecteur      Utilisateur   @relation("VisitesInspecteur", fields: [inspecteurId], references: [id])
  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  enseignantId    String?
  enseignant      Utilisateur?  @relation("VisitesEnseignant", fields: [enseignantId], references: [id])

  date        DateTime
  type        TypeVisite   @default(classe)
  statut      StatutVisite @default(planifiee)
  objet       String
  observations String?
  noteGlobale Float? // appréciation globale /20

  recommandations Recommandation[]

  creeLe     DateTime @default(now())
  misAJourLe DateTime @updatedAt

  @@index([inspecteurId])
  @@index([etablissementId])
  @@map("visites")
}

/// Recommandation issue d'une visite d'inspection, avec suivi de traitement.
model Recommandation {
  id       String                 @id @default(cuid())
  visiteId String
  visite   Visite                 @relation(fields: [visiteId], references: [id], onDelete: Cascade)
  texte    String
  priorite PrioriteRecommandation @default(moyenne)
  statut   StatutRecommandation   @default(ouverte)
  echeance DateTime?
  creeLe   DateTime               @default(now())

  @@index([visiteId])
  @@map("recommandations")
}

// ─────────────────────────────────────────────────────────────
//  Audit
// ─────────────────────────────────────────────────────────────

/// Trace d'une action effectuée sur la plateforme (audit, cahier §5.2.13).
/// Pas de FK vers Utilisateur : l'audit doit survivre à la suppression d'un compte.
model JournalActivite {
  id            String   @id @default(cuid())
  utilisateurId String?
  acteurEmail   String? // capture lisible même si le compte est supprimé ensuite
  action        String // ex : "demande_role.approuvee"
  cible         String? // ex : "Utilisateur:cuid"
  details       Json?
  creeLe        DateTime @default(now())

  @@index([utilisateurId])
  @@index([action])
  @@index([creeLe])
  @@map("journal_activite")
}
