// EduWeb Planner — Schéma Prisma de référence
// Phase 0/1 : RBAC à périmètre + authentification.
// Les entités de périmètre (Region, Etablissement, Cafop, Apfc) sont posées ici
// en version minimale ; elles seront étoffées en Phase 2 (cf. cahier des charges §3.1).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 7 : l'URL n'est plus déclarée ici.
  // - Au runtime, elle est fournie via le driver adapter (@prisma/adapter-pg) — voir src/lib/prisma.ts.
  // - Pour les migrations, elle est lue depuis prisma.config.ts (env DIRECT_URL).
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
//  Énumérations
// ─────────────────────────────────────────────────────────────

/// Statut du COMPTE — découplé du statut de la demande de rôle (cahier §6.1).
enum StatutCompte {
  en_attente_verification // inscrit, e-mail pas encore confirmé
  actif // e-mail confirmé : peut se connecter
  suspendu // bloqué temporairement par l'administrateur
  archive // archivé (conservation) — connexion impossible, réactivable
}

/// Statut d'une demande de rôle (cahier §6.6).
enum StatutDemandeRole {
  en_attente
  approuvee
  refusee
}

/// Type de jeton à usage unique (vérification e-mail / réinitialisation mot de passe).
enum TypeJeton {
  verification_email
  reinitialisation_mot_de_passe
}

// ── Phase 2 : structure & établissements ──

enum TypeEtablissement {
  prescolaire
  primaire
  college
  lycee
  technique
  formation_professionnelle
  technique_professionnel
  groupe_scolaire
  autre
}

enum StatutEtablissement {
  public
  prive
  confessionnel
  autre
}

enum TypeSalle {
  ordinaire
  laboratoire
  salle_informatique
  atelier
  salle_eps
  autre
}

/// Cycle d'un niveau scolaire.
enum CycleNiveau {
  prescolaire
  primaire
  college
  lycee
}

/// Régime de vacation (cahier §5.3.0-e) : simple ou double vacation.
enum RegimeVacation {
  simple
  double
}

/// Régime de notation par défaut (cahier §5.2.17) — séquentiel : 6 ou 8 séquences.
enum RegimeNotation {
  trimestre
  semestre
  sequence
}

/// Statut de présence d'un élève sur une séance (cahier §5.3.1).
enum StatutPresence {
  present
  absent
  retard
  excuse
}

/// Nature d'une notification in-app (pilote l'icône et la couleur d'affichage).
enum TypeNotification {
  info
  succes
  alerte
  role
}

/// Type de visite d'inspection (cahier §5 — inspection & supervision).
enum TypeVisite {
  classe
  etablissement
  suivi
}

/// Statut d'une visite d'inspection.
enum StatutVisite {
  planifiee
  realisee
  annulee
}

/// Priorité d'une recommandation d'inspection.
enum PrioriteRecommandation {
  basse
  moyenne
  haute
}

/// Statut de traitement d'une recommandation.
enum StatutRecommandation {
  ouverte
  en_cours
  traitee
}

/// Nature d'une cohorte de formation (cahier partie 5 — CAFOP & APFC).
enum TypeCohorte {
  cafop_promotion // promotion d'élèves-maîtres (CAFOP)
  apfc_session // session de formation continue (APFC)
}

/// Statut d'une cohorte de formation.
enum StatutCohorte {
  active
  cloturee
}

/// Formule d'abonnement Académie Premium (tarif selon l'effectif de l'établissement).
enum FormulePremium {
  petit // < 800 élèves
  grand // ≥ 800 élèves
}

/// Moyen de paiement (carte bancaire + Mobile Money ivoiriens).
enum ModePaiement {
  carte
  wave
  orange
  mtn
  moov
}

/// Statut d'un abonnement Premium.
enum StatutAbonnement {
  en_attente
  actif
  expire
}

/// Statut d'une demande de code promo (instruite par l'admin).
enum StatutDemandePromo {
  en_attente
  approuvee
  refusee
}

/// Nature d'une alerte SMS envoyée aux parents.
enum TypeAlerteSMS {
  absence
  note
  convocation
  info
}

/// Statut d'envoi d'un SMS (simulé tant qu'aucun fournisseur n'est branché).
enum StatutSMS {
  simule
  envoye
  echec
}

/// Statut d'un rendez-vous (parent ↔ personnel).
enum StatutRendezVous {
  demande
  confirme
  refuse
  annule
}

// ─────────────────────────────────────────────────────────────
//  RBAC : Rôle, Utilisateur, Demande de rôle
// ─────────────────────────────────────────────────────────────

/// Définition statique d'un profil d'accès (les 13 rôles, cahier §4.1).
model Role {
  id           String  @id @default(cuid())
  nomTechnique String  @unique // ex : "admin", "enseignant" (snake_case, cf. CLAUDE.md §8)
  libelle      String // ex : "Administrateur Système"
  description  String?
  rang         Int     @default(0) // ordre d'affichage / niveau de privilège indicatif

  utilisateurs Utilisateur[] @relation("RoleActif")
  demandes     DemandeRole[] @relation("RoleDemande")

  @@map("roles")
}

/// Compte d'un acteur de la plateforme (cahier §3.1, §4.2).
model Utilisateur {
  id             String       @id @default(cuid())
  email          String       @unique
  motDePasseHash String
  nom            String?
  prenoms        String?
  telephone      String?
  pays           String? // pays de l'utilisateur (détecté à l'inscription, modifiable au profil)
  sexe           String? // « F » / « M » — affiché notamment au registre d'appel
  matricule      String? // matricule élève (registre, bulletins)
  dateNaissance  DateTime? // date de naissance (fiche élève du registre)
  photoUrl       String?
  statutCompte   StatutCompte @default(en_attente_verification)
  emailVerifieLe DateTime?
  langue         String       @default("fr")

  // Rôle actif (technique). À l'inscription = "eleve" par défaut (cahier §6.2).
  roleActifId String
  roleActif   Role   @relation("RoleActif", fields: [roleActifId], references: [id])

  // Périmètre — nullable selon le rôle (cahier §3.2, §4.2).
  etablissementId String?
  etablissement   Etablissement? @relation(fields: [etablissementId], references: [id])
  cafopId         String?
  cafop           Cafop?         @relation(fields: [cafopId], references: [id])
  apfcId          String?
  apfc            Apfc?          @relation(fields: [apfcId], references: [id])
  regionId        String?
  region          Region?        @relation(fields: [regionId], references: [id])

  // Période d'essai (fixée par l'admin système à l'affectation à un établissement) : pendant
  // l'essai, seul l'espace Emplois du temps est éditable ; le reste est en lecture seule. Un
  // bandeau rouge avec compte à rebours invite à l'abonnement. `essaiFinLe` nul = pas d'essai.
  essaiDebutLe DateTime?
  essaiFinLe   DateTime?

  // Relations
  demandes            DemandeRole[]        @relation("DemandeUtilisateur")
  demandesTraitees    DemandeRole[]        @relation("DemandeTraitePar")
  echangesApprobation EchangeApprobation[] @relation("EchangeAuteur")
  liensCommeParent LienParentEleve[] @relation("Parent")
  liensCommeEleve  LienParentEleve[] @relation("Eleve")
  jetons           Jeton[]
  evenementsAppel  EvenementAppel[]  @relation("EvenementsEleve")
  evenementsSaisis EvenementAppel[]  @relation("EvenementsSaisis")
  seancesEnseignees   CahierTexte[]        @relation("SeancesEnseignant")
  demandesAccesCahier DemandeAccesCahier[] @relation("DemandesAccesCahier")
  // Vie scolaire (Phase 3)
  affectations     AffectationEnseignant[] @relation("AffectationsEnseignant")
  inscriptions     Inscription[]           @relation("InscriptionsEleve")
  appelsSaisis     Appel[]                 @relation("AppelsSaisis")
  presences        Presence[]              @relation("Presences")
  notesEleve         Note[]                  @relation("NotesEleve")
  notesSaisies       Note[]                  @relation("NotesSaisies")
  cahiersSaisis      CahierTexte[]           @relation("CahiersSaisis")
  notifications      Notification[]          @relation("NotificationsRecues")
  messagesEnvoyes    Message[]               @relation("MessagesEnvoyes")
  messagesRecus      Message[]               @relation("MessagesRecus")
  demandesPromo      DemandeCodePromo[]      @relation("DemandesPromo")
  invitationsCreees  InvitationFormation[]   @relation("InvitationsCreees")
  abonnementsSouscrits AbonnementPremium[]   @relation("AbonnementsSouscrits")
  rdvDemandes        RendezVous[]            @relation("RdvDemandes")
  rdvRecus           RendezVous[]            @relation("RdvRecus")
  visitesInspecteur  Visite[]                @relation("VisitesInspecteur")
  visitesEnseignant  Visite[]                @relation("VisitesEnseignant")
  competences        CompetenceEnseignant[]  @relation("CompetencesEnseignant")
  niveauxIntervention NiveauEnseignant[]     @relation("NiveauxEnseignant")
  // LMS « Aide et Formation »
  inscriptionsCours   InscriptionCours[]     @relation("InscriptionsCours")
  inscriptionsSession InscriptionSession[]   @relation("InscriptionsSession")
  tentativesQuiz      TentativeQuiz[]        @relation("TentativesQuiz")
  inscriptionsParcours InscriptionParcours[] @relation("InscriptionsParcours")
  badgesObtenus       BadgeObtenu[]          @relation("BadgesObtenus")
  soumissionsDevoir   SoumissionDevoir[]     @relation("SoumissionsDevoir")
  correctionsDevoir   SoumissionDevoir[]     @relation("CorrectionsDevoir")
  tuteurCours         TuteurCours[]          @relation("TuteurCours")
  pagesWikiCreees     PageWiki[]             @relation("PagesWikiCreees")
  pagesWikiModifiees  PageWiki[]             @relation("PagesWikiModifiees")
  revisionsWiki       RevisionWiki[]         @relation("RevisionsWiki")
  evaluationsWiki     EvaluationWiki[]       @relation("EvaluationsWiki")

  creeLe     DateTime @default(now())
  misAJourLe DateTime @updatedAt

  @@index([roleActifId])
  @@index([etablissementId])
  @@index([cafopId])
  @@index([apfcId])
  @@index([regionId])
  @@map("utilisateurs")
}

/// Demande d'attribution / changement de rôle (couvre l'inscription initiale, cahier §6).
model DemandeRole {
  id            String      @id @default(cuid())
  utilisateurId String
  utilisateur   Utilisateur @relation("DemandeUtilisateur", fields: [utilisateurId], references: [id], onDelete: Cascade)

  roleDemandeId String
  roleDemande   Role   @relation("RoleDemande", fields: [roleDemandeId], references: [id])

  statut StatutDemandeRole @default(en_attente)

  // Périmètre DÉCLARÉ par le demandeur (texte libre + identifiants si connus).
  structureDeclaree      String? // ex : nom de l'établissement saisi à l'inscription
  etablissementDeclareId String?
  cafopDeclareId         String?
  apfcDeclareId          String?
  regionDeclareeId       String?

  motif      String? // message du demandeur et/ou commentaire de l'administrateur
  creeLe     DateTime  @default(now())
  traiteLe   DateTime?
  // Anticipe la délégation future par périmètre (cahier §6.4) — aucune migration requise plus tard.
  traiteParId String?
  traitePar   Utilisateur? @relation("DemandeTraitePar", fields: [traiteParId], references: [id])

  echanges EchangeApprobation[]

  @@index([statut])
  @@index([utilisateurId])
  @@map("demandes_role")
}

/// Fil de discussion entre l'administration et le demandeur d'un rôle, mené sur la page
/// « Approbations des demandes de rôle », avec copie e-mail aux deux parties — afin de
/// clarifier le besoin réel du demandeur AVANT d'approuver son compte.
model EchangeApprobation {
  id          String      @id @default(cuid())
  demandeId   String
  demande     DemandeRole @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  auteurId    String
  auteur      Utilisateur @relation("EchangeAuteur", fields: [auteurId], references: [id], onDelete: Cascade)
  /// Vrai = message écrit par le DEMANDEUR ; faux = par l'administration (approbateur).
  duDemandeur Boolean     @default(false)
  contenu     String
  creeLe      DateTime    @default(now())

  @@index([demandeId, creeLe])
  @@map("echanges_approbation")
}

/// Relation N↔N entre un compte parent et un ou plusieurs comptes élèves (cahier §3.3).
model LienParentEleve {
  id       String      @id @default(cuid())
  parentId String
  parent   Utilisateur @relation("Parent", fields: [parentId], references: [id], onDelete: Cascade)
  eleveId  String
  eleve    Utilisateur @relation("Eleve", fields: [eleveId], references: [id], onDelete: Cascade)
  lien     String? // "père", "mère", "tuteur légal"…
  creeLe   DateTime    @default(now())

  @@unique([parentId, eleveId])
  @@index([parentId])
  @@index([eleveId])
  @@map("liens_parent_eleve")
}

/// Jeton à usage unique pour la confirmation d'e-mail et la réinitialisation de mot de passe (cahier §6.2, §6.5).
model Jeton {
  id            String      @id @default(cuid())
  token         String      @unique
  type          TypeJeton
  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  expireLe      DateTime
  utiliseLe     DateTime?
  creeLe        DateTime    @default(now())

  @@index([utilisateurId])
  @@map("jetons")
}

// ─────────────────────────────────────────────────────────────
//  Entités de périmètre (minimales en Phase 1, étoffées en Phase 2)
// ─────────────────────────────────────────────────────────────

/// Découpage administratif régional (rattachement DRENA/DRENAET, cahier §3.1).
/// Surcharge d'une permission de module pour un rôle (matrice des droits éditable).
/// Une ligne absente = valeur par défaut de la carte de navigation (item.roles).
/// `itemId` = identifiant d'ItemNav (ex : "registre-appel") ; `role` = nomTechnique du rôle.
model PermissionRole {
  id         String   @id @default(cuid())
  itemId     String
  role       String
  accorde    Boolean
  misAJourLe DateTime @updatedAt

  @@unique([itemId, role])
  @@map("permissions_role")
}

model Region {
  id   String  @id @default(cuid())
  nom  String
  code String? @unique
  /// Pays de rattachement — permet des répertoires régionaux multi-pays (déploiement sous-régional).
  pays String  @default("Côte d'Ivoire")

  etablissements Etablissement[]
  cafops         Cafop[]
  apfcs          Apfc[]
  utilisateurs   Utilisateur[]

  creeLe DateTime @default(now())

  @@unique([pays, nom])
  @@map("regions")
}

/// Établissement scolaire (cahier §3.1). Étendu en Phase 2bis avec la configuration
/// complète servant d'intrant au module Emplois du temps (cf. console de configuration).
model Etablissement {
  id        String              @id @default(cuid())
  nom       String
  code      String?             @unique
  type      TypeEtablissement   @default(college)
  statut    StatutEtablissement @default(public)
  ville     String?
  adresse   String?
  email     String?
  telephone String?
  /// Réseau confessionnel de rattachement (cascade quand statut = confessionnel) :
  /// SEDEC, Méthodiste, Protestants, Islamique… — null si non confessionnel.
  reseauConfessionnel String?
  /// Régime de vacation par défaut de l'établissement (surchargé par niveau si besoin).
  regimeVacation RegimeVacation @default(simple)

  /// Disciplines retirées de la liste de CET établissement (particularités locales :
  /// l'établissement n'est pas forcément aligné sur les conditions nationales).
  disciplinesMasquees String[] @default([])

  /// Indexation des classes au calcul : « @ » = lettres (6ème A…), « # » = chiffres (6ème 1…).
  indexationClasses String @default("@")

  /// Régime de notation choisi par le chef d'établissement : trimestriel, semestriel
  /// ou séquentiel (null = régime de la Configuration générale).
  regimeNotation RegimeNotation?
  /// Nombre de séquences (6 ou 8) lorsque le régime est séquentiel.
  nbSequences    Int?

  // ── Étape 1 : paramétrage institutionnel & en-tête de bulletin ──
  pays          String? @default("Côte d'Ivoire")
  // Pas de valeur par défaut : le slogan national officiel est déduit AUTOMATIQUEMENT de la
  // devise du pays de l'établissement (voir sloganOfficiel()). Repli sur cette valeur stockée
  // uniquement pour les rares États sans devise au référentiel.
  sloganBulletin String?
  ministere     String?
  anneeScolaire String? // ex : « 2025-2026 »
  fonctionChef  String? // ex : « Proviseur »
  nomChef       String? // NOM du chef d'établissement (en majuscules)
  prenomsChef   String? // Prénoms du chef d'établissement (casse titre)
  // Documents officiels (URLs Vercel Blob)
  emblemeUrl   String?
  logoUrl      String?
  cachetUrl    String?
  signatureUrl String?
  // Rapport d'établissement
  planRapport         String?
  presentationRapport String? @default("Accordéon")

  // ── Barème de conduite (registre d'appel) — points par événement, ajustable par le chef ──
  conduiteAbsenceNj     Float @default(0.5) // malus par absence non justifiée
  conduiteRetardNj      Float @default(0.25) // malus par retard non justifié
  conduiteObservation   Float @default(0.5) // malus par observation disciplinaire
  conduiteEncouragement Float @default(0.25) // bonus par encouragement

  // ── Étape 2 : dimensionnement & horaires ──
  effectifSouhaiteParClasse Int @default(40)
  nbSallesDisponibles       Int @default(0)
  creneauxParJour           Int @default(8)
  // Horaires journaliers (format « HH:MM »)
  horaireDebutMatin       String? @default("07:30")
  horairePauseMatinDebut  String? @default("09:45")
  horairePauseMatinFin    String? @default("10:05")
  horairePauseMidiDebut   String? @default("12:00")
  horaireRepriseApresMidi String? @default("15:00")
  horaireFinJournee       String? @default("18:00")

  // ── Contraintes d'emploi du temps paramétrables par l'établissement ──
  /// Paramètres conditionnels de double vacation (élèves), ajoutés au fil de l'eau :
  /// [{ "libelle": "Cours d'EPS", "doubleVacation": false }, …]
  conditionsVacation Json @default("[]")
  // Plages horaires d'EPS de l'établissement (format « HH:MM ») — le solveur y confine l'EPS.
  epsMatinDebut      String?
  epsMatinFin        String?
  epsApresMidiDebut  String?
  epsApresMidiFin    String?
  /// Garantir à chaque enseignant un jour de repos parmi les cinq jours (contrainte dure).
  reposEnseignant Boolean @default(true)
  /// Regrouper les heures creuses d'un enseignant sur une demi-journée (optimisation).
  regrouperHeuresCreuses Boolean @default(true)
  /// Autoriser des heures creuses dans l'EDT des élèves (pour souffler) — choix du chef.
  autoriserHeuresCreuses Boolean @default(false)
  /// Plages sans cours dans TOUT l'établissement : [{ "jour": 0-4, "moment": "matin"|"apresmidi"|"journee" }]
  plagesSansCours Json @default("[]")
  /// En double vacation, quels indices de classes ont cours le MATIN : "impairs" (1,3,5…) ou "pairs".
  doubleVacationMatin String @default("impairs")
  /// Volume horaire hebdomadaire dû par un enseignant du 1er cycle (n'intervient qu'au collège).
  /// Plafonne sa charge dans le solveur. 0 = non plafonné.
  volumeHoraire1erCycle Int @default(0)
  /// Volume horaire hebdomadaire dû par un enseignant du 2nd cycle (compétence sur les deux cycles).
  /// Plafonne sa charge dans le solveur. 0 = non plafonné.
  volumeHoraire2ndCycle Int @default(0)

  regionId String?
  region   Region? @relation(fields: [regionId], references: [id])

  utilisateurs   Utilisateur[]
  classes        Classe[]
  salles         Salle[]
  grilles        GrilleHoraire[]
  niveauxConfig  NiveauEtablissement[]
  champsEnseignant ChampEnseignant[]
  competences    CompetenceEnseignant[]
  niveauxEnseignant NiveauEnseignant[]
  effectifsEnseignant EffectifEnseignant[]
  creneaux       Creneau[]
  visites        Visite[]
  abonnementsPremium AbonnementPremium[]
  alertesSms     AlerteSMS[]

  creeLe     DateTime @default(now())
  misAJourLe DateTime @updatedAt

  @@index([regionId])
  @@map("etablissements")
}

/// Configuration d'un niveau pour un établissement : effectif total, vacation, classes calculées.
model NiveauEtablissement {
  id              String         @id @default(cuid())
  etablissementId String
  etablissement   Etablissement  @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  niveauId        String
  niveau          Niveau         @relation(fields: [niveauId], references: [id], onDelete: Cascade)
  effectif        Int            @default(0)
  vacation        RegimeVacation @default(simple)
  nbClasses       Int            @default(0)

  @@unique([etablissementId, niveauId])
  @@index([etablissementId])
  @@map("niveaux_etablissement")
}

/// Champ personnalisé requis pour l'enregistrement des enseignants d'un établissement.
model ChampEnseignant {
  id              String        @id @default(cuid())
  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  etiquette       String
  type            String        @default("text") // text | date | number | select
  placeholder     String?
  requis          Boolean       @default(false)
  ordre           Int           @default(0)

  @@index([etablissementId])
  @@map("champs_enseignant")
}

/// Compétence d'un enseignant : discipline qu'il est habilité à enseigner (intrant du solveur).
model CompetenceEnseignant {
  id              String        @id @default(cuid())
  enseignantId    String
  enseignant      Utilisateur   @relation("CompetencesEnseignant", fields: [enseignantId], references: [id], onDelete: Cascade)
  disciplineId    String
  discipline      Discipline    @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)

  @@unique([enseignantId, disciplineId])
  @@index([etablissementId])
  @@map("competences_enseignant")
}

/// Niveau auquel un enseignant intervient (intrant de l'affectation automatique).
model NiveauEnseignant {
  id              String        @id @default(cuid())
  enseignantId    String
  enseignant      Utilisateur   @relation("NiveauxEnseignant", fields: [enseignantId], references: [id], onDelete: Cascade)
  niveauId        String
  niveau          Niveau        @relation(fields: [niveauId], references: [id], onDelete: Cascade)
  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)

  @@unique([enseignantId, niveauId])
  @@index([etablissementId])
  @@map("niveaux_enseignant")
}

/// Effectif d'enseignants déclaré par cycle et discipline (intrant du solveur, approche par compteurs).
model EffectifEnseignant {
  id              String        @id @default(cuid())
  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  disciplineId    String
  discipline      Discipline    @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  cycle           CycleNiveau
  nombre          Int           @default(0)

  @@unique([etablissementId, disciplineId, cycle])
  @@index([etablissementId])
  @@map("effectifs_enseignant")
}

/// Niveau scolaire national (ex : 6ème, Seconde C) — cahier §3.1.
model Niveau {
  id    String      @id @default(cuid())
  nom   String      @unique
  code  String?     @unique
  ordre Int         @default(0)
  cycle CycleNiveau @default(college)

  classes       Classe[]
  grilles       GrilleHoraire[]
  niveauxConfig NiveauEtablissement[]
  enseignants   NiveauEnseignant[]

  @@map("niveaux")
}

/// Discipline / matière enseignée — cahier §3.1.
model Discipline {
  id      String  @id @default(cuid())
  nom     String  @unique
  code    String? @unique
  couleur String? // code couleur pour l'affichage des emplois du temps

  grilles      GrilleHoraire[]
  affectations AffectationEnseignant[]
  appels       Appel[]
  notes        Note[]
  cahiers      CahierTexte[]
  competences  CompetenceEnseignant[]
  effectifsEnseignant EffectifEnseignant[]

  @@map("disciplines")
}

/// Classe pédagogique au sein d'un établissement (ex : 6ème A) — cahier §3.1.
model Classe {
  id       String @id @default(cuid())
  nom      String
  effectif Int    @default(0)

  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  niveauId        String
  niveau          Niveau        @relation(fields: [niveauId], references: [id])

  anneeScolaireId String?
  anneeScolaire   AnneeScolaire? @relation(fields: [anneeScolaireId], references: [id])

  regimeVacation RegimeVacation @default(simple)

  affectations AffectationEnseignant[]
  inscriptions Inscription[]
  appels       Appel[]
  notes        Note[]
  cahiers      CahierTexte[]
  evenements   EvenementAppel[]

  creeLe     DateTime @default(now())
  misAJourLe DateTime @updatedAt

  @@index([etablissementId])
  @@index([niveauId])
  @@map("classes")
}

/// Salle physique d'un établissement (capacité + type) — cahier §3.1, §5.3.0-e.
model Salle {
  id        String    @id @default(cuid())
  nom       String
  capacite  Int       @default(0)
  type      TypeSalle @default(ordinaire)

  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)

  creeLe DateTime @default(now())

  @@index([etablissementId])
  @@map("salles")
}

/// Année scolaire (ex : « 2025-2026 ») — base des inscriptions (cahier §5.2.17).
model AnneeScolaire {
  id      String    @id @default(cuid())
  libelle String    @unique
  debut   DateTime?
  fin     DateTime?
  active  Boolean   @default(false)

  classes      Classe[]
  inscriptions Inscription[]

  @@map("annees_scolaires")
}

/// Grille horaire : volume hebdomadaire par niveau et discipline (cahier §5.3.0-e).
/// `etablissementId` null = modèle national par défaut ; non-null = surcharge établissement.
model GrilleHoraire {
  id          String @id @default(cuid())
  niveauId    String
  niveau      Niveau @relation(fields: [niveauId], references: [id], onDelete: Cascade)
  disciplineId String
  discipline  Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)

  etablissementId String?
  etablissement   Etablissement? @relation(fields: [etablissementId], references: [id], onDelete: Cascade)

  /// Pays du modèle : la grille NATIONALE (etablissementId null) est définie par pays.
  pays String @default("Côte d'Ivoire")

  heuresHebdo    Float @default(0) // volume horaire hebdomadaire (heures), dérivé des séances
  nbSeances      Int?  // nombre de séances hebdomadaires
  coefficient    Float @default(1)
  seancesMinutes Int[] @default([]) // durées (min) de chaque séance hebdomadaire — ex : [60,60,60,60]

  @@unique([niveauId, disciplineId, etablissementId])
  @@index([niveauId])
  @@index([etablissementId])
  @@map("grilles_horaires")
}

/// Configuration globale de la plateforme (singleton) — cahier §5.2.17.
model Configuration {
  id                   String         @id @default("global")
  anneeScolaireCourante String?
  regimeNotation       RegimeNotation @default(trimestre)
  misAJourLe           DateTime       @updatedAt

  @@map("configuration")
}

/// Centre d'Animation et de Formation Pédagogique (cahier §3.1).
model Cafop {
  id       String  @id @default(cuid())
  nom      String
  regionId String?
  region   Region? @relation(fields: [regionId], references: [id])

  /// Fiche du centre (tableau de bord « Gestion des CAFOP »).
  code         String? // ex. « CAF-ABG-001 »
  pays         String  @default("Côte d'Ivoire")
  drena        String? // Direction Régionale (DRENA) de rattachement, ex. « Abengourou »
  localite     String? // localité / site du centre, ex. « Bouaké 1 »
  directeur    String? // nom du directeur du centre
  directeurTel String? // téléphone du directeur
  effectif     Int     @default(0) // nombre d'élèves-maîtres du centre

  /// Documents officiels (Vercel Blob) — repli sur les armoiries nationales du pays si emblème absent.
  emblemeUrl   String? // armoiries du pays déposées
  logoUrl      String? // logo du CAFOP
  cachetUrl    String? // cachet du directeur
  signatureUrl String? // signature électronique du directeur

  utilisateurs    Utilisateur[]
  cohortes        Cohorte[]
  seances         SeanceCafop[]
  enseignants     EnseignantCafop[]
  profsPrincipaux ProfPrincipalCafop[]

  creeLe DateTime @default(now())

  @@index([regionId])
  @@map("cafops")
}

/// Enseignant d'un CAFOP (annuaire simple du centre : nom, prénoms, discipline).
model EnseignantCafop {
  id         String   @id @default(cuid())
  cafopId    String
  cafop      Cafop    @relation(fields: [cafopId], references: [id], onDelete: Cascade)
  nom        String
  prenoms    String?
  discipline String?
  creeLe     DateTime @default(now())

  principalDe ProfPrincipalCafop[]

  @@index([cafopId])
  @@map("enseignants_cafop")
}

/// Professeur principal d'un groupe-classe d'un CAFOP (renseigne le bulletin de notes).
model ProfPrincipalCafop {
  id           String          @id @default(cuid())
  cafopId      String
  cafop        Cafop           @relation(fields: [cafopId], references: [id], onDelete: Cascade)
  groupe       String // groupe-classe (ex. « B », « F2 »)
  enseignantId String
  enseignant   EnseignantCafop @relation(fields: [enseignantId], references: [id], onDelete: Cascade)
  creeLe       DateTime        @default(now())

  @@unique([cafopId, groupe])
  @@index([cafopId])
  @@index([enseignantId])
  @@map("prof_principaux_cafop")
}

/// Module de formation des élèves-maîtres (CAFOP) — matière évaluée dans les bulletins.
model ModuleCafop {
  id          String   @id @default(cuid())
  nom         String
  code        String?
  ordre       Int      @default(0)
  actif       Boolean  @default(true)
  coefficient Int      @default(1)
  /// Niveau de formation auquel le module est rattaché : 1re, 2e ou 3e année.
  annee       Int      @default(1)
  /// Semestre de dispensation du module (1 ou 2).
  semestre    Int?
  /// Jalons de planning du module.
  dateDebut      DateTime?
  dateFin        DateTime?
  datePretest    DateTime?
  dateEvaluation DateTime?
  /// Structure pédagogique : [{ nom (composante), themes: [nom] }] — cascade Module → Composante → Thème.
  composantes    Json?
  creeLe      DateTime @default(now())

  notes     NoteCafop[]
  seances   SeanceCafop[]
  presences PresenceCafop[]

  @@index([annee])
  @@map("modules_cafop")
}

/// Terme local désignant les CAFOP, par pays (ex. « CAFOP », « IFM », « CRFPE »).
model ParametreCafopPays {
  pays  String   @id
  terme String   @default("CAFOP")
  majLe DateTime @default(now()) @updatedAt

  @@map("parametres_cafop_pays")
}

/// Plan de formation (Formation Initiale des Maîtres) — document national par pays et année scolaire,
/// consultable par tous les CAFOP et pour tous les niveaux de formation.
model PlanFormation {
  id                 String   @id @default(cuid())
  pays               String
  anneeScolaire      String
  titre              String   @default("Plan de formation — Formation Initiale des Maîtres")
  intro              String? // texte de présentation
  signataire         String? // ancien libellé complet (legacy) — remplacé par prénoms + nom
  signatairePrenoms  String?
  signataireNom      String?
  signataireFonction String? // ex. « Le Directeur des Écoles, Lycées et Collèges (DELC) »
  cachetUrl          String? // cachet du DELC (Vercel Blob)
  signatureUrl       String? // signature électronique du DELC (Vercel Blob)
  publie             Boolean  @default(true)
  creeLe             DateTime @default(now())
  majLe              DateTime @default(now()) @updatedAt

  sections SectionPlanFormation[]

  @@unique([pays, anneeScolaire])
  @@map("plans_formation")
}

/// Section d'un plan : tableau de volumes (niveau null = commun) ou plan chronologique d'un niveau (1/2/3).
model SectionPlanFormation {
  id       String        @id @default(cuid())
  planId   String
  plan     PlanFormation @relation(fields: [planId], references: [id], onDelete: Cascade)
  ordre    Int           @default(0)
  /// null = section commune (volumes) ; 1/2/3 = plan chronologique de ce niveau de formation.
  niveau   Int?
  titre    String
  intro    String?
  note     String? // ex. note sur le module TIC
  /// En-têtes de colonnes (tableau JSON de chaînes).
  colonnes Json

  lignes LignePlanFormation[]

  @@index([planId])
  @@map("sections_plan_formation")
}

/// Ligne d'une section : cellules alignées sur les colonnes, ou bannière pleine largeur.
model LignePlanFormation {
  id        String               @id @default(cuid())
  sectionId String
  section   SectionPlanFormation @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  ordre     Int                  @default(0)
  /// « donnee » (cellules), « banniere » (texte pleine largeur), « total » (ligne mise en avant).
  type      String               @default("donnee")
  /// Cellules alignées sur `colonnes` (tableau JSON de chaînes).
  cellules  Json
  /// Texte des bannières (congés, jalons…).
  texte     String?
  /// Ton visuel : conges | jalon | note | total | null.
  ton       String?

  @@index([sectionId])
  @@map("lignes_plan_formation")
}

/// Antenne Pédagogique de Formation Continue (cahier §3.1).
model Apfc {
  id       String  @id @default(cuid())
  nom      String
  regionId String?
  region   Region? @relation(fields: [regionId], references: [id])

  utilisateurs Utilisateur[]
  cohortes     Cohorte[]

  creeLe DateTime @default(now())

  @@index([regionId])
  @@map("apfc")
}

/// Cohorte de formation : promotion d'élèves-maîtres (CAFOP) ou session de formation
/// continue (APFC). Rattachée à l'une des deux structures selon `type` (cahier partie 5).
model Cohorte {
  id        String        @id @default(cuid())
  type      TypeCohorte
  cafopId   String?
  cafop     Cafop?        @relation(fields: [cafopId], references: [id], onDelete: Cascade)
  apfcId    String?
  apfc      Apfc?         @relation(fields: [apfcId], references: [id], onDelete: Cascade)
  libelle   String
  anneeDebut Int?
  anneeFin   Int?
  dateDebut  DateTime?
  dateFin    DateTime?
  lieu       String?
  statut    StatutCohorte @default(active)

  /// Vue « Promotions » du tableau de bord CAFOP.
  nbCohortes  Int @default(1) // nombre de groupes/cohortes au sein de la promotion
  effectif    Int @default(0) // effectif d'élèves-maîtres de la promotion
  progression Int @default(0) // avancement de la formation, 0–100 (%)

  apprenants Apprenant[]

  creeLe DateTime @default(now())

  @@index([cafopId])
  @@index([apfcId])
  @@map("cohortes")
}

/// Apprenant d'une cohorte (élève-maître ou participant à une formation continue).
/// Simple enregistrement de liste (pas un compte Utilisateur) — alimenté par import CSV Moodle.
model Apprenant {
  id                   String   @id @default(cuid())
  cohorteId            String
  cohorte              Cohorte  @relation(fields: [cohorteId], references: [id], onDelete: Cascade)
  matricule            String?
  nom                  String
  prenoms              String?
  email                String?
  etablissementOrigine String?
  groupe               String? // classe pédagogique au sein de la promotion (ex. « F2 »)
  annee                Int? // année de formation : 1re, 2e ou 3e année
  /// Registre d'appel : sexe (« F »/« M »), date de naissance, téléphone (alerte SMS).
  sexe                 String?
  dateNaissance        DateTime?
  telephone            String?
  creeLe               DateTime @default(now())

  notes      NoteCafop[]
  presences  PresenceCafop[]
  evenements EvenementPresenceCafop[]

  @@index([cohorteId])
  @@map("apprenants")
}

/// Séance du cahier de texte d'un CAFOP (module, groupe-classe, contenu enseigné).
model SeanceCafop {
  id       String       @id @default(cuid())
  cafopId  String
  cafop    Cafop        @relation(fields: [cafopId], references: [id], onDelete: Cascade)
  moduleId String?
  module   ModuleCafop? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  groupe   String?
  /// Cascade pédagogique : Module → Composante → Thème.
  composante String?
  theme      String?
  discipline String?
  date       DateTime
  /// Horaires de la séance (format « HH:MM »).
  heureDebut String?
  heureFin   String?
  titre      String
  /// Sous-titres hiérarchisés : [{ niveau: 1|2|3, texte }].
  sousTitres Json?
  /// Objectifs de la séance : [texte].
  objectifs  Json?
  contenu    String? // résumé de la séance
  /// Date prévue de la prochaine séance.
  prochaineSeance DateTime?
  /// Exercices donnés (résumé, 500 caractères max).
  exercices    String?
  /// Lien du CAFOP en ligne communiqué pour les exercices (ex. https://cfpl2.eduweb.ci).
  exercicesUrl String?
  creeLe     DateTime @default(now())

  @@index([cafopId])
  @@map("seances_cafop")
}

/// Présence d'un élève-maître (registre d'appel CAFOP), un statut par jour.
model PresenceCafop {
  id          String    @id @default(cuid())
  apprenantId String
  apprenant   Apprenant @relation(fields: [apprenantId], references: [id], onDelete: Cascade)
  date        DateTime // normalisée à minuit (jour)
  statut      String    @default("present") // present | absent | retard
  /// Contexte de la séance et justification (registre d'appel enrichi).
  motif       String?
  justifie    Boolean      @default(false)
  heureSeance String? // créneau, ex. « 07h30 - 08h30 »
  moduleId    String?
  module      ModuleCafop? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  /// Contexte de la séance : discipline (plan de formation) et enseignant (compte « enseignant » du centre).
  discipline   String?
  enseignantId String?
  creeLe      DateTime     @default(now())

  // Une présence par élève-maître, par jour ET par créneau (plusieurs séances possibles le même jour).
  @@unique([apprenantId, date, heureSeance])
  @@index([apprenantId])
  @@index([moduleId])
  @@map("presences_cafop")
}

/// Événement de conduite au registre d'appel CAFOP (encouragement, observation, infirmerie).
model EvenementPresenceCafop {
  id             String    @id @default(cuid())
  type           String // encouragement | observation | infirmerie
  apprenantId    String
  apprenant      Apprenant @relation(fields: [apprenantId], references: [id], onDelete: Cascade)
  groupe         String?
  date           DateTime
  heureSeance    String?
  description    String
  accompagnateur String? // élève accompagnateur (infirmerie)
  saisiParId     String?
  creeLe         DateTime  @default(now())

  @@index([apprenantId])
  @@map("evenements_presence_cafop")
}

/// Note d'un élève-maître (CAFOP) dans un module, pour un semestre (bulletins).
model NoteCafop {
  id          String      @id @default(cuid())
  apprenantId String
  apprenant   Apprenant   @relation(fields: [apprenantId], references: [id], onDelete: Cascade)
  moduleId    String
  module      ModuleCafop @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type        String // type d'évaluation, ex. « Devoir surveillé », « Composition »
  valeur      Float
  bareme      Float       @default(20)
  coefficient Int         @default(1)
  semestre    Int         @default(1) // 1 ou 2
  creeLe      DateTime    @default(now())

  @@index([apprenantId])
  @@index([moduleId])
  @@map("notes_cafop")
}

// ─────────────────────────────────────────────────────────────
//  Vie scolaire — Phase 3
// ─────────────────────────────────────────────────────────────

/// Affectation d'un enseignant à une classe pour une discipline (cahier §3.1, §8.5).
model AffectationEnseignant {
  id           String      @id @default(cuid())
  enseignantId String
  enseignant   Utilisateur @relation("AffectationsEnseignant", fields: [enseignantId], references: [id], onDelete: Cascade)
  classeId     String
  classe       Classe      @relation(fields: [classeId], references: [id], onDelete: Cascade)
  disciplineId String
  discipline   Discipline  @relation(fields: [disciplineId], references: [id])

  creeLe DateTime @default(now())

  @@unique([enseignantId, classeId, disciplineId])
  @@index([classeId])
  @@index([enseignantId])
  @@map("affectations_enseignant")
}

/// Inscription d'un élève à une classe pour une année scolaire (cahier §3.1, §8.5).
model Inscription {
  id      String      @id @default(cuid())
  eleveId String
  eleve   Utilisateur @relation("InscriptionsEleve", fields: [eleveId], references: [id], onDelete: Cascade)
  classeId String
  classe   Classe     @relation(fields: [classeId], references: [id], onDelete: Cascade)

  anneeScolaireId String?
  anneeScolaire   AnneeScolaire? @relation(fields: [anneeScolaireId], references: [id])

  creeLe DateTime @default(now())

  @@unique([eleveId, anneeScolaireId])
  @@index([classeId])
  @@index([eleveId])
  @@map("inscriptions")
}

/// Séance d'appel pour une classe à une date donnée (cahier §5.3.1).
model Appel {
  id           String      @id @default(cuid())
  classeId     String
  classe       Classe      @relation(fields: [classeId], references: [id], onDelete: Cascade)
  disciplineId String?
  discipline   Discipline? @relation(fields: [disciplineId], references: [id])
  date         DateTime // jour de la séance (normalisé à minuit UTC)
  heureSeance  String? // créneau de la séance, ex : « 07h30 - 08h30 » (filtre + heatmap)
  saisiParId   String
  saisiPar     Utilisateur @relation("AppelsSaisis", fields: [saisiParId], references: [id])

  presences Presence[]

  creeLe DateTime @default(now())

  @@index([classeId])
  @@index([date])
  @@map("appels")
}

/// Présence d'un élève sur une séance d'appel (cahier §5.3.1).
model Presence {
  id          String         @id @default(cuid())
  appelId     String
  appel       Appel          @relation(fields: [appelId], references: [id], onDelete: Cascade)
  eleveId     String
  eleve       Utilisateur    @relation("Presences", fields: [eleveId], references: [id], onDelete: Cascade)
  statut      StatutPresence @default(present)
  commentaire String?
  motif       String? // motif d'absence / de retard (colonne MOTIF du registre)
  justifie    Boolean        @default(false) // absence/retard justifié auprès de l'établissement

  @@unique([appelId, eleveId])
  @@index([eleveId])
  @@map("presences")
}

/// Nature d'un événement de vie scolaire saisi depuis le registre d'appel.
enum TypeEvenementAppel {
  encouragement // valorise l'élève (bonus de conduite)
  observation // perturbation ou comportement inadapté (malus de conduite)
  infirmerie // admission à l'infirmerie (neutre pour la conduite)
}

/// Événement par élève saisi depuis le registre d'appel (colonne ACTIONS).
/// Encouragements et observations entrent dans la note de conduite.
model EvenementAppel {
  id      String             @id @default(cuid())
  type    TypeEvenementAppel
  eleveId String
  eleve   Utilisateur        @relation("EvenementsEleve", fields: [eleveId], references: [id], onDelete: Cascade)
  classeId String
  classe   Classe            @relation(fields: [classeId], references: [id], onDelete: Cascade)
  date        DateTime // jour de la séance
  heureSeance String? // créneau de la séance
  description String // rédigée avec aide IA, ajustable par l'utilisateur
  accompagnateur String? // infirmerie : élève accompagnateur (optionnel)
  saisiParId String
  saisiPar   Utilisateur @relation("EvenementsSaisis", fields: [saisiParId], references: [id])

  creeLe DateTime @default(now())

  @@index([eleveId])
  @@index([classeId])
  @@map("evenements_appel")
}

/// Créneau d'emploi du temps généré (cahier §5.3.0). Noms dénormalisés pour un affichage direct.
model Creneau {
  id              String        @id @default(cuid())
  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  classeId        String
  classeNom       String
  disciplineId    String
  disciplineNom   String
  enseignantId    String
  enseignantNom   String
  salleNom        String
  jour            Int // 0 = lundi … 5 = samedi
  periode         Int // index de période dans la journée
  duree           Int @default(1) // nombre de périodes
  anneeScolaireId String?
  creeLe          DateTime @default(now())

  @@index([etablissementId])
  @@index([classeId])
  @@map("creneaux")
}

/// Note d'évaluation d'un élève dans une discipline, pour une période (cahier §5.3.4).
model Note {
  id           String      @id @default(cuid())
  eleveId      String
  eleve        Utilisateur @relation("NotesEleve", fields: [eleveId], references: [id], onDelete: Cascade)
  classeId     String
  classe       Classe      @relation(fields: [classeId], references: [id], onDelete: Cascade)
  disciplineId String
  discipline   Discipline  @relation(fields: [disciplineId], references: [id])

  libelle    String // ex : « Devoir 1 », « Composition »
  valeur     Float
  sur        Float  @default(20)
  periode    Int    @default(1) // 1..3 (trimestre) ou 1..2 (semestre)
  saisiParId String
  saisiPar   Utilisateur @relation("NotesSaisies", fields: [saisiParId], references: [id])

  creeLe DateTime @default(now())

  @@index([classeId])
  @@index([eleveId])
  @@index([disciplineId])
  @@map("notes")
}

/// Entrée du cahier de texte : contenu d'une séance et travail à faire, consigné par
/// l'enseignant pour une classe/discipline à une date donnée (cahier §5.3.2).
/// Statut d'une séance du cahier de texte.
enum StatutSeanceCahier {
  brouillon
  publie
}

/// Statut d'une demande d'accès à une séance (parents, conseillers pédagogiques…).
enum StatutDemandeAcces {
  en_attente
  accordee
  refusee
}

model CahierTexte {
  id           String      @id @default(cuid())
  classeId     String
  classe       Classe      @relation(fields: [classeId], references: [id], onDelete: Cascade)
  disciplineId String
  discipline   Discipline  @relation(fields: [disciplineId], references: [id])
  date         DateTime // jour de la séance (normalisé à minuit UTC)

  statut       StatutSeanceCahier @default(publie)
  titre        String? // titre de la leçon / séance
  heureDebut   String? // « 07:30 »
  dureeMin     Int?
  typeActivite String? // Cours, TD, TP, Évaluation…
  amorce       String? // situation d'amorce
  sousTitres   Json? // [{ niveau: 1..4, texte }] — plan hiérarchique de la séance
  contenu      String // résumé de la séance / leçon traitée
  activitesApprentissage Json? // [texte]
  activitesEvaluation    Json? // [texte]
  prochaineSeanceLe      DateTime?
  travailAFaire String? // devoirs / travail à faire à la maison

  enseignantId String?
  enseignant   Utilisateur? @relation("SeancesEnseignant", fields: [enseignantId], references: [id], onDelete: SetNull)
  saisiParId String
  saisiPar   Utilisateur @relation("CahiersSaisis", fields: [saisiParId], references: [id])

  demandesAcces DemandeAccesCahier[]

  creeLe     DateTime @default(now())
  misAJourLe DateTime @updatedAt

  @@index([classeId])
  @@index([disciplineId])
  @@index([date])
  @@index([statut])
  @@map("cahier_texte")
}

/// Demande d'accès d'un parent / conseiller à une séance du cahier de texte,
/// à valider par l'équipe pédagogique (colonne « Demandes d'accès » de la page).
model DemandeAccesCahier {
  id          String             @id @default(cuid())
  cahierId    String
  cahier      CahierTexte        @relation(fields: [cahierId], references: [id], onDelete: Cascade)
  demandeurId String
  demandeur   Utilisateur        @relation("DemandesAccesCahier", fields: [demandeurId], references: [id], onDelete: Cascade)
  statut      StatutDemandeAcces @default(en_attente)
  creeLe      DateTime           @default(now())
  traiteLe    DateTime?

  @@index([cahierId])
  @@index([statut])
  @@map("demandes_acces_cahier")
}

/// Notification in-app destinée à un utilisateur (socle commun, cahier §5.3.x).
/// Tout module crée une notification via `creerNotification` (src/lib/notifications).
model Notification {
  id             String           @id @default(cuid())
  destinataireId String
  destinataire   Utilisateur      @relation("NotificationsRecues", fields: [destinataireId], references: [id], onDelete: Cascade)
  type           TypeNotification @default(info)
  titre          String
  message        String
  lien           String? // route interne optionnelle (ex : « /app/mon-identification »)
  lu             Boolean          @default(false)
  luLe           DateTime?
  creeLe         DateTime         @default(now())

  @@index([destinataireId, lu])
  @@index([creeLe])
  @@map("notifications")
}

/// Message in-app entre deux utilisateurs (communication interne, cahier partie 5/7).
model Message {
  id             String      @id @default(cuid())
  expediteurId   String
  expediteur     Utilisateur @relation("MessagesEnvoyes", fields: [expediteurId], references: [id], onDelete: Cascade)
  destinataireId String
  destinataire   Utilisateur @relation("MessagesRecus", fields: [destinataireId], references: [id], onDelete: Cascade)
  contenu        String
  lu             Boolean     @default(false)
  creeLe         DateTime    @default(now())

  @@index([expediteurId])
  @@index([destinataireId, lu])
  @@map("messages")
}

/// Code promotionnel applicable à un abonnement Premium (cahier partie 7 — Académie Premium).
model CodePromo {
  id          String   @id @default(cuid())
  code        String   @unique
  libelle     String
  pourcentage Int // remise en %
  partenaire  Boolean  @default(false) // taux préférentiel partenaire (IZEN, E-School…)
  actif       Boolean  @default(true)
  creeLe      DateTime @default(now())

  abonnements AbonnementPremium[]

  @@map("codes_promo")
}

/// Demande d'un code promo, instruite par l'administrateur (« Approbations de codes promos »).
model DemandeCodePromo {
  id               String             @id @default(cuid())
  demandeurId      String
  demandeur        Utilisateur        @relation("DemandesPromo", fields: [demandeurId], references: [id], onDelete: Cascade)
  etablissementNom String?
  motif            String
  statut           StatutDemandePromo @default(en_attente)
  codeAttribue     String?
  traiteLe         DateTime?
  creeLe           DateTime           @default(now())

  @@index([statut])
  @@map("demandes_code_promo")
}

/// Abonnement à l'Académie Premium pour un établissement (mode démo : paiement simulé).
model AbonnementPremium {
  id                   String           @id @default(cuid())
  etablissementId      String?
  etablissement        Etablissement?   @relation(fields: [etablissementId], references: [id], onDelete: SetNull)
  souscritParId        String
  souscritPar          Utilisateur      @relation("AbonnementsSouscrits", fields: [souscritParId], references: [id], onDelete: Cascade)
  formule              FormulePremium
  montantBase          Int // FCFA
  codePromoId          String?
  codePromo            CodePromo?       @relation(fields: [codePromoId], references: [id])
  pourcentageReduction Int              @default(0)
  montantFinal         Int // FCFA après remise
  modePaiement         ModePaiement
  statut               StatutAbonnement @default(en_attente)
  dateDebut            DateTime         @default(now())
  dateFin              DateTime
  creeLe               DateTime         @default(now())

  @@index([etablissementId])
  @@map("abonnements_premium")
}

/// Alerte SMS envoyée à un parent (un enregistrement par destinataire).
/// Champs dénormalisés : l'historique survit à la suppression des entités liées.
model AlerteSMS {
  id               String        @id @default(cuid())
  /// Établissement émetteur (cloisonnement de l'historique par périmètre). Null pour les
  /// alertes issues d'un CAFOP ou pour les anciennes lignes non rattachables par leur nom.
  etablissementId  String?
  etablissement    Etablissement? @relation(fields: [etablissementId], references: [id], onDelete: SetNull)
  /// Pays émetteur (établissement ou CAFOP) — cloisonnement inter-pays même sans FK établissement.
  pays             String?
  /// Nom de la structure émettrice, conservé pour l'affichage et l'historique (établissement ou CAFOP).
  etablissementNom String?
  telephone        String
  contenu          String
  type             TypeAlerteSMS @default(info)
  statut           StatutSMS     @default(simule)
  envoyeParEmail   String?
  creeLe           DateTime      @default(now())

  @@index([creeLe])
  @@index([etablissementId])
  @@index([pays])
  @@map("alertes_sms")
}

/// Nature d'un événement de trafic du site (≠ TypeVisite du module Inspection).
enum TypeTraficSite {
  visite // chargement de la plateforme par un navigateur (1 fois par session)
  connexion // authentification réussie
}

/// Trafic du site — compteur de visites + connexions (widget temps réel de l'accueil).
model VisiteSite {
  id     String         @id @default(cuid())
  type   TypeTraficSite
  chemin String?
  creeLe DateTime       @default(now())

  @@index([creeLe])
  @@index([type])
  @@map("visites_site")
}

/// Rendez-vous entre un demandeur (parent/personnel) et un destinataire (personnel).
model RendezVous {
  id             String           @id @default(cuid())
  demandeurId    String
  demandeur      Utilisateur      @relation("RdvDemandes", fields: [demandeurId], references: [id], onDelete: Cascade)
  destinataireId String
  destinataire   Utilisateur      @relation("RdvRecus", fields: [destinataireId], references: [id], onDelete: Cascade)
  date           DateTime
  motif          String
  statut         StatutRendezVous @default(demande)
  creeLe         DateTime         @default(now())

  @@index([demandeurId])
  @@index([destinataireId])
  @@map("rendez_vous")
}

/// Visite d'inspection d'un établissement (et éventuellement d'un enseignant) — cahier partie 6.
model Visite {
  id              String        @id @default(cuid())
  inspecteurId    String
  inspecteur      Utilisateur   @relation("VisitesInspecteur", fields: [inspecteurId], references: [id])
  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  enseignantId    String?
  enseignant      Utilisateur?  @relation("VisitesEnseignant", fields: [enseignantId], references: [id])

  date        DateTime
  type        TypeVisite   @default(classe)
  statut      StatutVisite @default(planifiee)
  objet       String
  observations String?
  noteGlobale Float? // appréciation globale /20

  recommandations Recommandation[]

  creeLe     DateTime @default(now())
  misAJourLe DateTime @updatedAt

  @@index([inspecteurId])
  @@index([etablissementId])
  @@map("visites")
}

/// Recommandation issue d'une visite d'inspection, avec suivi de traitement.
model Recommandation {
  id       String                 @id @default(cuid())
  visiteId String
  visite   Visite                 @relation(fields: [visiteId], references: [id], onDelete: Cascade)
  texte    String
  priorite PrioriteRecommandation @default(moyenne)
  statut   StatutRecommandation   @default(ouverte)
  echeance DateTime?
  creeLe   DateTime               @default(now())

  @@index([visiteId])
  @@map("recommandations")
}

// ─────────────────────────────────────────────────────────────
//  Audit
// ─────────────────────────────────────────────────────────────

/// Trace d'une action effectuée sur la plateforme (audit, cahier §5.2.13).
/// Pas de FK vers Utilisateur : l'audit doit survivre à la suppression d'un compte.
model JournalActivite {
  id            String   @id @default(cuid())
  utilisateurId String?
  acteurEmail   String? // capture lisible même si le compte est supprimé ensuite
  action        String // ex : "demande_role.approuvee"
  cible         String? // ex : "Utilisateur:cuid"
  details       Json?
  creeLe        DateTime @default(now())

  @@index([utilisateurId])
  @@index([action])
  @@index([creeLe])
  @@map("journal_activite")
}

// ─────────────────────────────────────────────────────────────
//  LMS « Aide et Formation » (Phase 1) — cours e-learning + sessions
//  Contenu géré par l'admin système. `type`/`format`/`statut` sont des String
//  (volontairement extensibles : ajouter une valeur ne nécessite pas de migration).
// ─────────────────────────────────────────────────────────────

/// Catégorie de la bibliothèque de formation (ex. « Prise en main », « Emplois du temps »).
model CategorieFormation {
  id          String   @id @default(cuid())
  nom         String
  description String?
  icone       String? // nom d'icône lucide (affichage)
  ordre       Int      @default(0)
  creeLe      DateTime @default(now())

  cours Cours[]

  @@map("categories_formation")
}

/// Département de l'organisation EduWeb Planner — présenté sur la page d'accueil
/// (« Nos départements ») et géré depuis Système › Départements (admin système).
model Departement {
  id          String   @id @default(cuid())
  nom         String
  description String?
  /// Regroupement pour les onglets de la page d'accueil (ex : produit, pedagogie, support, pilotage).
  categorie   String   @default("general")
  /// Nom d'icône lucide-react (ex : « Compass », « GraduationCap »).
  icone       String?
  /// Accent de la carte : « forest » | « gold ».
  couleur     String   @default("forest")
  ordre       Int      @default(0)
  actif       Boolean  @default(true)
  creeLe      DateTime @default(now())
  majLe       DateTime @updatedAt

  @@index([actif, ordre])
  @@map("departements")
}

/// Cours / parcours de formation à l'utilisation de la plateforme.
model Cours {
  id           String              @id @default(cuid())
  titre        String
  slug         String              @unique
  description  String?
  categorieId  String?
  categorie    CategorieFormation? @relation(fields: [categorieId], references: [id], onDelete: SetNull)
  imageUrl     String?
  niveau       String? // « debutant » | « intermediaire » | « avance »
  publicCible  String[] // identifiants de rôles visés (vide = tous)
  statut       String              @default("brouillon") // « brouillon » | « publie »
  ordre        Int                 @default(0)
  dureeMinutes Int? // durée estimée cumulée (indicative)
  seuilCompletion       Int     @default(100) // % de leçons requis pour valider le cours et débloquer l'attestation
  progressionSequentielle Boolean @default(false) // module verrouillé tant que le précédent n'est pas validé
  estGuide              Boolean @default(false) // « Guide d'utilisation » (figure sur « Guides d'utilisateurs ») vs formation (sur « Formations »)
  attestationSignataire String? // nom du signataire figurant sur l'attestation
  attestationFonction   String? // fonction / titre du signataire
  attestationMention    String? // mention libre affichée sur l'attestation
  creeLe       DateTime            @default(now())
  misAJourLe   DateTime            @updatedAt

  modules      ModuleCours[]
  inscriptions InscriptionCours[]
  etapes       EtapeParcours[]
  tuteurs      TuteurCours[]
  pagesWiki    PageWiki[]

  @@index([categorieId])
  @@index([statut])
  @@map("cours")
}

/// Leçon d'un cours. `type` est un String (extensible : texte, vidéo, fichier, lien, …).
model ModuleCours {
  id           String   @id @default(cuid())
  coursId      String
  cours        Cours    @relation(fields: [coursId], references: [id], onDelete: Cascade)
  titre        String
  type         String   @default("texte") // « texte » | « video » | « fichier » | « lien »
  contenu      String? // texte riche (Markdown) OU URL (vidéo / lien)
  fichierUrl   String? // document déposé (Vercel Blob) pour type « fichier »
  fichierNom   String?
  ordre        Int      @default(0)
  dureeMinutes Int?
  creeLe       DateTime @default(now())

  progressions ProgressionModule[]
  quiz         Quiz?
  devoir       Devoir?

  @@index([coursId])
  @@map("modules_cours")
}

/// Inscription d'un utilisateur à un cours (+ progression globale).
model InscriptionCours {
  id               String      @id @default(cuid())
  utilisateurId    String
  utilisateur      Utilisateur @relation("InscriptionsCours", fields: [utilisateurId], references: [id], onDelete: Cascade)
  coursId          String
  cours            Cours       @relation(fields: [coursId], references: [id], onDelete: Cascade)
  statut           String      @default("en_cours") // « en_cours » | « termine »
  progressionPct   Int         @default(0)
  source           String      @default("auto") // « auto » (progression/quiz/devoir) | « nominative » (inscrit par un admin) | « session » (via une session)
  dateInscription  DateTime    @default(now())
  dateFin          DateTime?
  derniereActivite DateTime    @default(now())

  progressions ProgressionModule[]

  @@unique([utilisateurId, coursId])
  @@index([coursId])
  @@map("inscriptions_cours")
}

/// Paramétrage administrateur d'un séminaire / d'une formation figée (statique).
/// Sert à la couverture (bannière) affichée sur la carte ET au pré-remplissage du certificat.
model ConfigSeminaire {
  id                String   @id @default(cuid())
  slug              String   @unique // identifiant du séminaire, ex. « communication-pastorale »
  formateurs        String[] @default([]) // e-mails des formateurs habilités (pilotage des activités, zone « exploitation pédagogique »)
  couvertureUrl     String? // image de couverture / bannière (Vercel Blob)
  organisation      String? // organisation délivrant le certificat
  logoUrl           String? // logo du certificat
  formateur         String? // nom du formateur (pré-rempli)
  directeur         String? // nom du directeur / signataire
  directeurFonction String? // fonction du signataire
  signatureUrl      String? // signature scannée (Vercel Blob)
  cachetUrl         String? // cachet officiel (Vercel Blob)
  qrImageUrl        String? // image du QR de vérification
  dateSignature     String? // date de signature (ISO « AAAA-MM-JJ »)
  certificatModele  String? // identifiant du modèle de certificat choisi (cf. /certificats/modeles.json)
  lieu              String? // lieu de délivrance
  creeLe            DateTime @default(now())
  misAJourLe        DateTime @updatedAt

  @@map("config_seminaires")
}

/// Réponse nominative d'un participant à une activité de sondage d'un séminaire
/// (ex. « Sondage d'entrée » : un mot choisi + une idée saisie). Modifiable par l'auteur.
model ReponseSondage {
  id            String   @id @default(cuid())
  seminaire     String // slug du séminaire
  activite      String // identifiant d'activité, ex. « sondage-entree »
  utilisateurId String // auteur (réponse nominative, modifiable)
  mot           String? // mot choisi dans le nuage
  idee          String? // idée saisie (2e temps)
  creeLe        DateTime @default(now())
  misAJourLe    DateTime @updatedAt

  @@unique([seminaire, activite, utilisateurId])
  @@index([seminaire, activite])
  @@map("reponses_sondage")
}

/// État de partage d'une activité de sondage, piloté par le formateur
/// (nuage de mots partagé aux élèves, collecte d'idées ouverte).
model EtatSondage {
  id            String   @id @default(cuid())
  seminaire     String
  activite      String
  nuagePartage  Boolean  @default(false)
  ideesOuvertes Boolean  @default(false)
  creeLe        DateTime @default(now())
  misAJourLe    DateTime @updatedAt

  @@unique([seminaire, activite])
  @@map("etats_sondage")
}

/// Production nominative d'un participant à une activité de séminaire (auto-évaluation,
/// QCM, atelier, engagement). Visible du formateur dans l'« espace formateur ». Modifiable.
model ProductionSeminaire {
  id            String   @id @default(cuid())
  seminaire     String
  activite      String // « auto-evaluation » | « qcm » | « atelier-reformuler » | « atelier-corriger » | « engagement »
  utilisateurId String
  contenu       String? // texte ou JSON (bilan, score, réponse)
  creeLe        DateTime @default(now())
  misAJourLe    DateTime @updatedAt

  @@unique([seminaire, activite, utilisateurId])
  @@index([seminaire, activite])
  @@map("productions_seminaire")
}

/// Complétion d'une leçon par un apprenant inscrit.
model ProgressionModule {
  id             String           @id @default(cuid())
  inscriptionId  String
  inscription    InscriptionCours @relation(fields: [inscriptionId], references: [id], onDelete: Cascade)
  moduleId       String
  module         ModuleCours      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  termine        Boolean          @default(false)
  dateCompletion DateTime?

  @@unique([inscriptionId, moduleId])
  @@index([moduleId])
  @@map("progressions_module")
}

/// Session de formation programmée (webinaire / atelier / présentiel) avec inscription en ligne.
model SessionFormation {
  id           String   @id @default(cuid())
  titre        String
  description  String?
  coursIds     String[] // cours associés (facultatif) — identifiants des cours liés
  format       String   @default("webinaire") // « webinaire » | « atelier » | « presentiel »
  animateur    String?
  dateDebut    DateTime
  dateFin      DateTime? // date & heure de fin (facultatif)
  dureeMinutes Int?
  lienVisio    String?
  lieu         String?
  placesMax    Int?
  publicCible  String[] // rôles visés (vide = tous)
  pays         String? // restreint à un pays (facultatif)
  statut       String   @default("planifiee") // « planifiee » | « terminee » | « annulee »
  creeLe       DateTime @default(now())

  inscriptions InscriptionSession[]
  invitations  InvitationFormation[]

  @@index([dateDebut])
  @@map("sessions_formation")
}

/// Inscription d'un utilisateur à une session de formation.
model InscriptionSession {
  id              String           @id @default(cuid())
  utilisateurId   String
  utilisateur     Utilisateur      @relation("InscriptionsSession", fields: [utilisateurId], references: [id], onDelete: Cascade)
  sessionId       String
  session         SessionFormation @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  statut          String           @default("inscrit") // « en_attente » | « inscrit » | « present » | « absent »
  dateInscription DateTime         @default(now())

  @@unique([utilisateurId, sessionId])
  @@index([sessionId])
  @@map("inscriptions_session")
}

/// Lien d'invitation à une session de formation : partageable, avec validation admin par
/// défaut, ou auto-validation si l'invité présente le code associé.
model InvitationFormation {
  id         String           @id @default(cuid())
  token      String           @unique @default(cuid()) // segment d'URL du lien d'invitation
  sessionId  String
  session    SessionFormation @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  code       String? // code d'auto-validation (facultatif) — présenté par l'invité pour être validé immédiatement
  actif      Boolean          @default(true)
  expiration DateTime? // au-delà, le lien n'accepte plus d'inscription
  placesMax  Int? // plafond d'inscriptions via ce lien (facultatif)
  creeParId  String?
  creePar    Utilisateur?     @relation("InvitationsCreees", fields: [creeParId], references: [id], onDelete: SetNull)
  creeLe     DateTime         @default(now())

  @@index([sessionId])
  @@map("invitations_formation")
}

// ── LMS Phase 2 : évaluations (quiz) ──

/// Quiz d'évaluation rattaché à une leçon de type « quiz » (1:1). La leçon est validée
/// (progression) lorsque l'apprenant atteint le seuil de réussite.
model Quiz {
  id            String      @id @default(cuid())
  moduleId      String      @unique
  module        ModuleCours @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  consigne      String?
  seuilReussite Int         @default(70) // pourcentage minimal pour valider
  mode          String      @default("formatif") // « formatif » (feedback pédagogique) | « sommatif » (noté)
  revelationSolutions String @default("apres_tentative") // « jamais » | « apres_tentative » | « apres_reussite » | « toujours »
  verificationImmediate Boolean @default(true) // autoriser le bouton « Vérifier » par question (correction immédiate)
  creeLe        DateTime    @default(now())

  questions  QuestionQuiz[]
  tentatives TentativeQuiz[]

  @@map("quiz")
}

/// Question d'un quiz. `type` extensible (choix unique / multiple / vrai-faux).
model QuestionQuiz {
  id     String   @id @default(cuid())
  quizId String
  quiz   Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  enonce     String
  type       String   @default("choix_unique") // « choix_unique » | « choix_multiple » | « vrai_faux »
  points     Int      @default(1)
  ordre      Int      @default(0)
  explication String? // correction / feedback détaillé, révélé selon la politique du quiz
  creeLe     DateTime @default(now())

  choix ChoixQuestion[]

  @@index([quizId])
  @@map("questions_quiz")
}

/// Choix (proposition de réponse) d'une question.
model ChoixQuestion {
  id         String       @id @default(cuid())
  questionId String
  question   QuestionQuiz @relation(fields: [questionId], references: [id], onDelete: Cascade)
  texte      String
  correct    Boolean      @default(false)
  ordre      Int          @default(0)
  apparie    String? // « association » : libellé de droite à relier ; « texte_a_trous » : alternatives (a|b) ; sinon null

  @@index([questionId])
  @@map("choix_question")
}

/// Tentative d'un apprenant à un quiz (score + réussite).
model TentativeQuiz {
  id            String      @id @default(cuid())
  quizId        String
  quiz          Quiz        @relation(fields: [quizId], references: [id], onDelete: Cascade)
  utilisateurId String
  utilisateur   Utilisateur @relation("TentativesQuiz", fields: [utilisateurId], references: [id], onDelete: Cascade)
  score         Int
  scoreMax      Int
  pourcentage   Int
  reussi        Boolean
  reponses      Json? // instantané { questionId: [choixIds] }
  dateTentative DateTime    @default(now())

  @@index([quizId])
  @@index([utilisateurId])
  @@map("tentatives_quiz")
}

// ── LMS Phase 3 : parcours multi-cours + badges ──

/// Badge de reconnaissance décerné à la complétion d'un parcours (gamification).
model Badge {
  id          String   @id @default(cuid())
  nom         String
  description String?
  icone       String? // nom d'icône lucide (affichage)
  couleur     String   @default("gold") // jeton de teinte : « gold » | « forest » | « rose » | « bleu »
  creeLe      DateTime @default(now())

  parcours   Parcours[]
  obtentions BadgeObtenu[]

  @@map("badges")
}

/// Parcours = séquence ordonnée de cours ; sa complétion décerne un badge (facultatif).
model Parcours {
  id          String   @id @default(cuid())
  titre       String
  slug        String   @unique
  description String?
  niveau      String? // « debutant » | « intermediaire » | « avance »
  publicCible String[] // rôles visés (vide = tous)
  statut      String   @default("brouillon") // « brouillon » | « publie »
  ordre       Int      @default(0)
  badgeId     String?
  badge       Badge?   @relation(fields: [badgeId], references: [id], onDelete: SetNull)
  creeLe      DateTime @default(now())
  misAJourLe  DateTime @updatedAt

  etapes       EtapeParcours[]
  inscriptions InscriptionParcours[]

  @@index([statut])
  @@map("parcours")
}

/// Étape d'un parcours : un cours à une position donnée (un cours peut figurer dans plusieurs parcours).
model EtapeParcours {
  id         String   @id @default(cuid())
  parcoursId String
  parcours   Parcours @relation(fields: [parcoursId], references: [id], onDelete: Cascade)
  coursId    String
  cours      Cours    @relation(fields: [coursId], references: [id], onDelete: Cascade)
  ordre      Int      @default(0)

  @@unique([parcoursId, coursId])
  @@index([parcoursId])
  @@index([coursId])
  @@map("etapes_parcours")
}

/// Inscription d'un apprenant à un parcours (+ progression agrégée sur les cours du parcours).
model InscriptionParcours {
  id               String      @id @default(cuid())
  utilisateurId    String
  utilisateur      Utilisateur @relation("InscriptionsParcours", fields: [utilisateurId], references: [id], onDelete: Cascade)
  parcoursId       String
  parcours         Parcours    @relation(fields: [parcoursId], references: [id], onDelete: Cascade)
  statut           String      @default("en_cours") // « en_cours » | « termine »
  progressionPct   Int         @default(0)
  dateInscription  DateTime    @default(now())
  dateFin          DateTime?
  derniereActivite DateTime    @default(now())

  @@unique([utilisateurId, parcoursId])
  @@index([parcoursId])
  @@map("inscriptions_parcours")
}

/// Badge obtenu par un apprenant (une seule fois par badge).
model BadgeObtenu {
  id            String      @id @default(cuid())
  utilisateurId String
  utilisateur   Utilisateur @relation("BadgesObtenus", fields: [utilisateurId], references: [id], onDelete: Cascade)
  badgeId       String
  badge         Badge       @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  dateObtention DateTime    @default(now())

  @@unique([utilisateurId, badgeId])
  @@index([badgeId])
  @@map("badges_obtenus")
}

// ── LMS Phase 4-B : devoirs (dépôts corrigés par un tuteur) ──

/// Devoir rattaché à une leçon de type « devoir » (1:1) : dépôt texte et/ou fichier, corrigé par un tuteur.
model Devoir {
  id             String      @id @default(cuid())
  moduleId       String      @unique
  module         ModuleCours @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  consigne       String?
  accepteTexte   Boolean     @default(true)
  accepteFichier Boolean     @default(true)
  noteSur        Int         @default(20)
  dateLimite     DateTime?
  creeLe         DateTime    @default(now())

  soumissions SoumissionDevoir[]

  @@map("devoirs")
}

/// Dépôt d'un apprenant + correction du tuteur (note, appréciation ; l'observation IA est un brouillon éditable).
model SoumissionDevoir {
  id             String       @id @default(cuid())
  devoirId       String
  devoir         Devoir       @relation(fields: [devoirId], references: [id], onDelete: Cascade)
  utilisateurId  String
  utilisateur    Utilisateur  @relation("SoumissionsDevoir", fields: [utilisateurId], references: [id], onDelete: Cascade)
  texte          String?
  fichierUrl     String?
  fichierNom     String?
  statut         String       @default("soumis") // « soumis » | « corrige »
  note           Int?
  appreciation   String?
  correcteurId   String?
  correcteur     Utilisateur? @relation("CorrectionsDevoir", fields: [correcteurId], references: [id], onDelete: SetNull)
  dateSoumission DateTime     @default(now())
  dateCorrection DateTime?

  @@unique([devoirId, utilisateurId])
  @@index([devoirId])
  @@index([utilisateurId])
  @@map("soumissions_devoir")
}

/// Tuteur correcteur désigné pour un cours (compte existant, sans nouveau rôle global).
model TuteurCours {
  id            String      @id @default(cuid())
  coursId       String
  cours         Cours       @relation(fields: [coursId], references: [id], onDelete: Cascade)
  utilisateurId String
  utilisateur   Utilisateur @relation("TuteurCours", fields: [utilisateurId], references: [id], onDelete: Cascade)
  creeLe        DateTime    @default(now())

  @@unique([coursId, utilisateurId])
  @@index([utilisateurId])
  @@map("tuteurs_cours")
}

// ── LMS Phase 5 : travaux collaboratifs (wiki) ──

/// Page de travail collaboratif (wiki) d'un cours — contenu HTML riche SANITISÉ à l'enregistrement.
model PageWiki {
  id            String       @id @default(cuid())
  coursId       String
  cours         Cours        @relation(fields: [coursId], references: [id], onDelete: Cascade)
  titre         String
  contenu       String       @default("")
  creeParId     String?
  creePar       Utilisateur? @relation("PagesWikiCreees", fields: [creeParId], references: [id], onDelete: SetNull)
  misAJourParId String?
  misAJourPar   Utilisateur? @relation("PagesWikiModifiees", fields: [misAJourParId], references: [id], onDelete: SetNull)
  creeLe        DateTime     @default(now())
  misAJourLe    DateTime     @updatedAt

  revisions   RevisionWiki[]
  evaluations EvaluationWiki[]

  @@index([coursId])
  @@map("pages_wiki")
}

/// Révision (historique) d'une page wiki — instantané du contenu à chaque modification.
model RevisionWiki {
  id       String       @id @default(cuid())
  pageId   String
  page     PageWiki     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  contenu  String
  auteurId String?
  auteur   Utilisateur? @relation("RevisionsWiki", fields: [auteurId], references: [id], onDelete: SetNull)
  creeLe   DateTime     @default(now())

  @@index([pageId])
  @@map("revisions_wiki")
}

/// Évaluation d'une page wiki — par un PAIR (apprenant inscrit) ou par le FORMATEUR/TUTEUR.
model EvaluationWiki {
  id           String      @id @default(cuid())
  pageId       String
  page         PageWiki    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  evaluateurId String
  evaluateur   Utilisateur @relation("EvaluationsWiki", fields: [evaluateurId], references: [id], onDelete: Cascade)
  type         String // « pair » | « tuteur »
  note         Int? // sur 20 (facultative)
  commentaire  String?
  creeLe       DateTime    @default(now())
  misAJourLe   DateTime    @updatedAt

  @@unique([pageId, evaluateurId])
  @@index([pageId])
  @@map("evaluations_wiki")
}

/// Réponse ANONYME à l'enquête de satisfaction de fin de séminaire (accès public,
/// sans authentification). Notes de 1 à 5 (0 à 10 pour la recommandation) + champs libres.
model EnqueteSatisfaction {
  id                  String   @id @default(cuid())
  seminaire           String   @default("magnifica-humanitas")
  appreciationGlobale Int? // 1..5
  contenuClair        Int? // 1..5
  contenuPertinent    Int? // 1..5
  activitesUtiles     Int? // 1..5
  rythmeAdapte        Int? // 1..5
  navigationAisee     Int? // 1..5
  applicationConcrete Int? // 1..5
  usageResponsable    Int? // 1..5
  recommandation      Int? // 0..10 (indice de recommandation)
  pointsForts         String?
  pointsAmeliorer     String?
  suggestions         String?
  role                String?
  pays                String?
  creeLe              DateTime @default(now())

  @@index([seminaire, creeLe])
  @@map("enquetes_satisfaction")
}
